---
import { resolveObjectRef } from '../utils/object_resolver';
import ObjRef from './obj_ref/ObjRef.astro';

interface ModuleReference {
  key: string;
  label: string;
  isClass: boolean;
}

interface Props {
  constants: Record<string, any>;
  allModuleClasses: Record<string, any>;
  allModuleTags: Record<string, any>;
}

const { constants, allModuleClasses, allModuleTags } = Astro.props;

// Define all possible references to check
const moduleReferences: ModuleReference[] = [
  {
    key: 'module_class_ref_1',
    label: 'Class 1',
    isClass: true,
  },
  {
    key: 'module_class_ref_2',
    label: 'Class 2',
    isClass: true,
  },
  {
    key: 'module_tag_ref_1',
    label: 'Tag 1',
    isClass: false,
  },
  {
    key: 'module_tag_ref_2',
    label: 'Tag 2',
    isClass: false,
  },
];
---

<div
  class="ability-references"
  style="margin-top: 1rem; font-size: 0.9rem; color: #666;"
>
  {moduleReferences.map((ref) => {
    const refValue = constants[ref.key];
    if (!refValue) return null;
    
    const resolvedObj = ref.isClass 
      ? resolveObjectRef(refValue, allModuleClasses)
      : resolveObjectRef(refValue, allModuleTags);
    
    return (
      <span style="margin-right: 0.5rem;">
        {resolvedObj ? (
          <ObjRef obj={resolvedObj} useHref={false} />
        ) : (
          refValue
        )}
      </span>
    );
  })}
</div>
