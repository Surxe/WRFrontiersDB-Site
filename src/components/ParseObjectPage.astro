import Page from './Page.astro';
import type { LocalizationKey } from '../types/localization';

export interface Props {
  title?: string | LocalizationKey | LocalizationKey[];
  description?: string;
  localizedDescriptions?: { lang: string; description: string }[];
  metaImage?: string;
  url?: string;
  type?: string;
  headerImage?: string;
}

const {
  title,
  description,
  localizedDescriptions,
  metaImage,
  url,
  type,
  headerImage,
} = Astro.props;

// Basic parse object page layout, e.g. pages/modules/[id]/[version].astro. Not pages/modules.astro.
---

<Page
  title={title}
  description={description}
  localizedDescriptions={localizedDescriptions}
  metaImage={metaImage}
  url={url}
  type={type}
  headerImage={headerImage}
>
  <slot name="head" slot="head" />
  <slot />
</Page>
