---
import Icon from '../../components/Icon.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import type { ObjRefData } from '../../utils/obj_ref';
import type { LocalizationKey } from '../../types/localization';
import { getDefaultString } from '../../utils/localization';

interface Props {
  objRefData: ObjRefData;
  showIcon: boolean;
  iconSize: number;
}

const { objRefData, showIcon, iconSize } = Astro.props;

// Helper function to check if text is an array
const isMultipleTexts = (text: LocalizationKey | LocalizationKey[]) => {
  return Array.isArray(text);
};


---

{
  showIcon && objRefData.iconPath && (
    <Icon
      iconPath={objRefData.iconPath}
      altText={`${isMultipleTexts(objRefData.text) ? objRefData.text.map(t => getDefaultString(t)).join(' ') : getDefaultString(objRefData.text)} icon`}
      size={iconSize}
      color={objRefData.iconColor}
    />
  )
}
{
  objRefData.textBackgroundColor ? (
    <div
      style={`display: inline-block; padding: 2px 8px; background-color: #${objRefData.textBackgroundColor}; border-radius: 4px;`}
    >
      {isMultipleTexts(objRefData.text) ? (
        objRefData.text.map((localizationKey, index) => (
          <>
            <LocalizedText id={`text-${index}`} tag="span" localizationKey={localizationKey} />
            {index < (objRefData.text as LocalizationKey[]).length - 1 && ' '}
          </>
        ))
      ) : (
        <LocalizedText tag="span" localizationKey={objRefData.text} />
      )}
    </div>
  ) : (
    isMultipleTexts(objRefData.text) ? (
      objRefData.text.map((localizationKey, index) => (
        <>
          <LocalizedText id={`text-${index}`} tag="span" localizationKey={localizationKey} />
          {index < (objRefData.text as LocalizationKey[]).length - 1 && ' '}
        </>
      ))
    ) : (
      <LocalizedText tag="span" localizationKey={objRefData.text} />
    )
  )
}
