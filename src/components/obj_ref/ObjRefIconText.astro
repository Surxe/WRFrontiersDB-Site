---
import Icon from '../../components/Icon.astro';
import ObjRefText from './ObjRefText.astro';
import type { ObjRefData } from '../../utils/obj_ref';
import type { LocalizationKey } from '../../types/localization';
import { getDefaultString } from '../../utils/localization';

interface Props {
  objRefData: ObjRefData;
  showIcon: boolean;
  iconSize: number;
}

const { objRefData, showIcon, iconSize } = Astro.props;

// Helper function to check if text is an array
const isMultipleTexts = (text: LocalizationKey | LocalizationKey[]) => {
  return Array.isArray(text);
};
---

{
  showIcon && objRefData.iconPath && (
    <Icon
      iconPath={objRefData.iconPath}
      altText={`${isMultipleTexts(objRefData.text) ? objRefData.text.map((t) => getDefaultString(t)).join(' ') : getDefaultString(objRefData.text)} icon`}
      size={iconSize}
      color={objRefData.iconColor}
    />
  )
}

<ObjRefText objRefData={objRefData} />
