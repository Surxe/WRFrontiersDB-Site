---
import ObjRefIconText from './ObjRefIconText.astro';
import ObjRefHover from './ObjRefHover.astro';
import LocalizedText from '../LocalizedText.astro';
import Icon from '../Icon.astro';
import { isCoreModule, getCoreModuleCategory } from '../../utils/core_modules';
import type { ParseObject } from '../../types/parse_object';
import StatValueChoices from '../StatEmbedLocalizedText.astro';
import '../../styles/ObjRef.css';

interface Props {
  obj: ParseObject;
  iconSize?: number;
  showIcon?: boolean;
  useOnHover?: boolean;
  onHoverStatChoices?: typeof StatValueChoices;
  useHref?: boolean;
}

const {
  obj,
  iconSize = 24,
  showIcon = true,
  useOnHover = false,
  onHoverStatChoices,
  useHref = true,
} = Astro.props;

// Check if this is a core module
const isCore = isCoreModule(obj);

let objRefData;
let pageUrl;

if (isCore) {
  // For core modules, use the category object for display but link to the module
  const category = getCoreModuleCategory(obj);
  if (!category) {
    throw new Error('Core module has no valid category');
  }
  
  // Use category data for display (icon, hover text)
  objRefData = {
    text: category.name,
    iconPath: category.icon_path as string,
    hoverText: category.description,
  } as any;
  
  // Link to the actual module page
  pageUrl = `/${obj.parseObjectUrl}/${obj.id}`;
} else {
  // For non-core modules, use standard behavior
  const { getObjRefData } = await import('../../utils/obj_ref');
  objRefData = getObjRefData(obj);
  pageUrl = `/${obj.parseObjectUrl}/${obj.id}`;
}

// Validate hover
if (useOnHover && !objRefData.hoverText) {
  throw new Error(
    'useOnHover is enabled but no hoverText is available for this object.'
  );
}

// Validate href
if (useHref && !pageUrl) {
  throw new Error(
    'useHref is enabled but no page URL is available for this object.'
  );
}
---

<span class="page-ref-wrapper">
  {
    isCore ? (
      useHref ? (
        <a href={pageUrl}>
          {showIcon && objRefData.iconPath && (
            <Icon
              iconPath={objRefData.iconPath}
              altText={`${objRefData.text.en || objRefData.text.InvariantString} icon`}
              size={iconSize}
              color={objRefData.iconColor}
            />
          )}
          <LocalizedText tag="span" localizationKey={objRefData.text} />
          <LocalizedText tag="span" localizationKey={obj.name || { InvariantString: obj.id, en: obj.id }} />
        </a>
      ) : (
        <span>
          {showIcon && objRefData.iconPath && (
            <Icon
              iconPath={objRefData.iconPath}
              altText={`${objRefData.text.en || objRefData.text.InvariantString} icon`}
              size={iconSize}
              color={objRefData.iconColor}
            />
          )}
          <LocalizedText tag="span" localizationKey={objRefData.text} />
          <LocalizedText tag="span" localizationKey={obj.name || { InvariantString: obj.id, en: obj.id }} />
        </span>
      )
    ) : (
      useHref ? (
        <a href={pageUrl}>
          <ObjRefIconText
            objRefData={objRefData}
            showIcon={showIcon}
            iconSize={iconSize}
          />
        </a>
      ) : (
        <span>
          <ObjRefIconText
            objRefData={objRefData}
            showIcon={showIcon}
            iconSize={iconSize}
          />
        </span>
      )
    )
  }
  <ObjRefHover
    objRefData={objRefData}
    useOnHover={useOnHover}
    onHoverStatChoices={onHoverStatChoices}
  />
</span>
