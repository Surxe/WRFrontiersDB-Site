---
import ObjRefIconText from './ObjRefIconText.astro';
import ObjRefHover from './ObjRefHover.astro';
import { getObjRefData } from '../../utils/obj_ref';
import type { ParseObject } from '../../types/parse_object';
import type { StatValueChoices } from '../../types/stat';
import '../../styles/obj_ref.css';

// Always color background if the objRefData supports it
// Always color icon if the objRefData supports it
// Use Icon only if showIcon
// Use href only if useHref
// Use hover only if useOnHover

interface Props {
  obj: ParseObject;
  iconSize?: number;
  showIcon?: boolean;
  useOnHover?: boolean;
  onHoverStatChoices?: StatValueChoices;
  useHref?: boolean;
}

const {
  obj,
  iconSize = 24,
  showIcon = true,
  useOnHover = false,
  onHoverStatChoices,
  useHref: initialUseHref = true,
} = Astro.props;

// Determine if we should use href based on production status for modules
let useHref = initialUseHref;

// Get the page reference data (localization key, icon path, hex color)
const objRefData = getObjRefData(obj);

// Try to get slug for objects that have slugs, otherwise fall back to ID
let urlSegment = obj.id;
const slugableObjectTypes = [
  'modules',
  'pilots',
  'pilot_talents',
  'pilot_classes',
  'pilot_personalities',
  'pilot_talent_types',
  'character_presets',
  'module_categories',
  'module_groups',
  'currencies',
];

if (slugableObjectTypes.includes(obj.parseObjectUrl || '')) {
  // For modules, only require slugs for production-ready modules
  if (obj.parseObjectClass === 'Module' && obj.production_status !== 'Ready') {
    // Non-production modules don't get links
    useHref = false;
  } else {
    // Import slug map as JSON module
    try {
      const slugMapModule = await import('../../../public/slug_map.json');
      const slugMap = slugMapModule.default;
      const slug = slugMap[obj.id as keyof typeof slugMap];

      if (!slug) {
        throw new Error(
          `No slug found for ${obj.parseObjectUrl} object with ID ${obj.id}. All production ${obj.parseObjectClass} objects must have a valid slug entry in the slug map.`
        );
      }

      urlSegment = slug;
    } catch (error) {
      throw new Error(
        `Failed to load slug map. Slug map must exist at public/slug_map.json for build to succeed: ${error}`
      );
    }
  }
}

const pageUrl = `/${obj.parseObjectUrl}/${urlSegment}`;

// Validate hover
if (useOnHover && !objRefData.hoverText) {
  throw new Error(
    'useOnHover is enabled but no hoverText is available for this object.'
  );
}

// Validate href
if (useHref && !pageUrl) {
  throw new Error(
    'useHref is enabled but no page URL is available for this object.'
  );
}
---

<span class="page-ref-wrapper">
  {
    useHref ? (
      <a href={pageUrl}>
        <ObjRefIconText
          objRefData={objRefData}
          showIcon={showIcon}
          iconSize={iconSize}
        />
      </a>
    ) : (
      <span>
        <ObjRefIconText
          objRefData={objRefData}
          showIcon={showIcon}
          iconSize={iconSize}
        />
      </span>
    )
  }
  <ObjRefHover
    objRefData={objRefData}
    useOnHover={useOnHover}
    onHoverStatChoices={onHoverStatChoices}
  />
</span>
