---
import ObjRefIconText from './ObjRefIconText.astro';
import ObjRefHover from './ObjRefHover.astro';
import { getObjRefData } from '../../utils/obj_ref';
import type { ParseObject } from '../../types/parse_object';
import type { StatValueChoices } from '../StatEmbedLocalizedText.astro';
import '../../styles/ObjRef.css';

// Always color background if the objRefData supports it
// Always color icon if the objRefData supports it
// Use Icon only if showIcon
// Use href only if useHref
// Use hover only if useOnHover

interface Props {
  obj: ParseObject;
  iconSize?: number;
  showIcon?: boolean;
  useOnHover?: boolean;
  onHoverStatChoices?: StatValueChoices;
  useHref?: boolean;
}

const {
  obj,
  iconSize = 24,
  showIcon = true,
  useOnHover = false,
  onHoverStatChoices,
  useHref = true,
} = Astro.props;

// Get the page reference data (localization key, icon path, hex color)
const objRefData = getObjRefData(obj);

// Try to get slug for objects that have slugs, otherwise fall back to ID
let urlSegment = obj.id;
const slugableObjectTypes = [
  'modules',
  'pilots', 
  'pilot_talents',
  'pilot_classes',
  'pilot_personalities', 
  'pilot_talent_types',
  'character_presets',
  'module_categories',
  'module_groups'
];

if (slugableObjectTypes.includes(obj.parseObjectUrl)) {
  // Import slug map as JSON module
  try {
    const slugMapModule = await import('../../../public/slug-map.json');
    const slugMap = slugMapModule.default;
    const slug = slugMap[obj.id];
    
    if (!slug) {
      throw new Error(`No slug found for ${obj.parseObjectUrl} object with ID ${obj.id}. All objects with slugs must have a valid slug entry in the slug map.`);
    }
    
    urlSegment = slug;
  } catch (error) {
    throw new Error(`Failed to load slug map. Slug map must exist at public/slug-map.json for build to succeed: ${error}`);
  }
}

const pageUrl = `/${obj.parseObjectUrl}/${urlSegment}`;

// Validate hover
if (useOnHover && !objRefData.hoverText) {
  throw new Error(
    'useOnHover is enabled but no hoverText is available for this object.'
  );
}

// Validate href
if (useHref && !pageUrl) {
  throw new Error(
    'useHref is enabled but no page URL is available for this object.'
  );
}
---

<span class="page-ref-wrapper">
  {
    useHref ? (
      <a href={pageUrl}>
        <ObjRefIconText
          objRefData={objRefData}
          showIcon={showIcon}
          iconSize={iconSize}
        />
      </a>
    ) : (
      <span>
        <ObjRefIconText
          objRefData={objRefData}
          showIcon={showIcon}
          iconSize={iconSize}
        />
      </span>
    )
  }
  <ObjRefHover
    objRefData={objRefData}
    useOnHover={useOnHover}
    onHoverStatChoices={onHoverStatChoices}
  />
</span>
