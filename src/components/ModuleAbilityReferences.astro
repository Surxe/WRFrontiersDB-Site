---
interface ModuleReference {
  key: string;
}

interface Props {
  constants: Record<string, any>;
}

const { constants } = Astro.props;

// Define all possible references to check
const moduleReferences: ModuleReference[] = [
  {
    key: 'module_class_ref_1',
  },
  {
    key: 'module_class_ref_2',
  },
  {
    key: 'module_tag_ref_1',
  },
  {
    key: 'module_tag_ref_2',
  },
];
---

<div
  class="ability-references"
  style="margin-top: 1rem; font-size: 0.9rem; color: #666;"
>
  {moduleReferences.map((ref) => {
    const refValue = constants[ref.key];
    if (!refValue) return null;
    
    return (
      <span style="margin-right: 0.5rem;">
        {refValue}
      </span>
    );
  })}
</div>
