---
import BaseNavBox from './BaseNavBox.astro';
import { getParseObjects } from '../../utils/parse_object';
import type { PilotPersonality } from '../../types/pilot';

// Load pilot personalities
const pilotPersonalities = getParseObjects<PilotPersonality>('Objects/PilotPersonality.json');

// Sort personalities by name
const sortedPersonalities = Object.entries(pilotPersonalities)
  .sort(([_a, a], [_b, b]) => {
    const nameA = a.name?.Key || a.id;
    const nameB = b.name?.Key || b.id;
    return nameA.localeCompare(nameB);
  });
---

<BaseNavBox title="Pilot Personalities">
  {
    sortedPersonalities.map(([personalityId, personality]) => (
      <a href={`/${import.meta.env.BASE_URL}pilot_personalities/${personalityId}`}>
        {personality.name?.Key || personality.id}
      </a>
    ))
  }
</BaseNavBox>
