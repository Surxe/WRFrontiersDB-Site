---
import BaseNavBox from './BaseNavBox.astro';
import { getParseObjects } from '../../utils/parse_object';
import { getBotCoreModules } from '../../utils/bot_modules';
import type { Module } from '../../types/module';

interface Props {
  botId: string;
  currentModuleId: string;
}

const { botId, currentModuleId } = Astro.props;

// Load modules and presets
const modules = getParseObjects<Module>('Objects/Module.json');
// Get core modules for this bot (excluding current module)
const botCoreModules = getBotCoreModules(botId, modules, currentModuleId);

// Get bot name for title
const botName =
  botId.charAt(0).toUpperCase() + botId.slice(1).replace(/-/g, ' ');
---

{
  botCoreModules.length > 0 && (
    <BaseNavBox
      title={`${botName} Core Modules`}
      objects={botCoreModules.map((m) => [m.id, m])}
    />
  )
}
