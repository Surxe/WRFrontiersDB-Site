---
import ModulesNavBox from './ModulesNavBox.astro';
import { getParseObjects } from '../../utils/parse_object';
import type { ModuleGroup } from '../../types/module_group';

// Get all module groups
const moduleGroups = getParseObjects<ModuleGroup>('Objects/ModuleGroup.json');

// Sort groups by sort_order
const sortedGroupIds = Object.values(moduleGroups)
  .sort((a, b) => (a.sort_order || 999) - (b.sort_order || 999))
  .map((group) => group.id);
---

<div class="modules-navboxes-container">
  {
    sortedGroupIds.map((moduleGroupId) => (
      <ModulesNavBox moduleGroupId={moduleGroupId} />
    ))
  }
</div>

<style>
  .modules-navboxes-container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 20px;
  }

  .modules-navboxes-container > :global(*) {
    flex: 1;
    min-width: 250px;
    max-width: 400px;
  }
</style>
