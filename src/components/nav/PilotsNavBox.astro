---
import BaseNavBox from './BaseNavBox.astro';
import { getParseObjects } from '../../utils/parse_object';
import { refToId } from '../../utils/object_reference';
import { PILOT_TYPE_LEGENDARY_REF } from '../../utils/constants';
import type { Pilot, PilotType } from '../../types/pilot';

interface Props {
  isHero: boolean;
}

const { isHero } = Astro.props;

// Load pilots and pilot types
const pilots = getParseObjects<Pilot>('Objects/Pilot.json');
const pilotTypes = getParseObjects<PilotType>('Objects/PilotType.json');

// Filter pilots based on isHero parameter
const filteredPilots = Object.entries(pilots)
  .filter(([_, pilot]) => {
    const pilotTypeId = refToId(pilot.pilot_type_ref);
    const pilotType = pilotTypes[pilotTypeId];
    if (!pilotType) return false;

    if (isHero) {
      return pilot.pilot_type_ref === PILOT_TYPE_LEGENDARY_REF;
    } else {
      return pilot.pilot_type_ref !== PILOT_TYPE_LEGENDARY_REF;
    }
  })
  .sort(([_a, a], [_b, b]) => {
    // Sort by pilot name
    const nameA = a.first_name?.Key || a.id;
    const nameB = b.first_name?.Key || b.id;
    return nameA.localeCompare(nameB);
  });

// Generate descriptive title
const pilotCount = filteredPilots.length;
const heroTitle = `Hero Pilots (${pilotCount})`;
const commonTitle = `Common Pilots (${pilotCount})`;
---

<BaseNavBox title={isHero ? heroTitle : commonTitle} objects={filteredPilots} />
