---
/* global console */
import BaseNavBox from './BaseNavBox.astro';
import { getParseObjects, getParseObject } from '../../utils/parse_object';
import { prepareObjectList } from '../../utils/list';
import { getDefaultString } from '../../utils/localization';
import type { Module } from '../../types/module';
import type { ModuleGroup } from '../../types/module_group';
import { refToId } from '../../utils/object_reference';

interface Props {
  moduleGroupId: string;
}

const { moduleGroupId } = Astro.props;

// Load modules
const modules = getParseObjects<Module>('Objects/Module.json');

// Filter modules for this specific group
const allGroupModules = Object.entries(modules).filter(
  ([_, module]) =>
    module.module_group_ref &&
    refToId(module.module_group_ref) === moduleGroupId
);

// Use prepareObjectList to filter production-ready modules
const filteredModules = prepareObjectList(Object.fromEntries(allGroupModules), {
  prodReadyOnly: true,
}).sort(([_a, a], [_b, b]) => {
  // Sort by module name
  const nameA = a.name?.Key || a.id;
  const nameB = b.name?.Key || b.id;
  return nameA.localeCompare(nameB);
});

// Get localized title for this module group
let title = moduleGroupId;
try {
  const moduleGroup = getParseObject<ModuleGroup>(
    moduleGroupId,
    'Objects/ModuleGroup.json'
  );
  title = getDefaultString(moduleGroup.name) || moduleGroup.id;
} catch {
  console.warn(`ModuleGroup ${moduleGroupId} not found for ModulesNavBox`);
}
---

<BaseNavBox title={title} objects={filteredModules} />
