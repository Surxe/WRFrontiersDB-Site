---
interface Props {
  title: string;
  pilots: Array<[string, any]>;
  baseUrl?: string;
}

const { title, pilots, baseUrl = '' } = Astro.props;
---

<nav class="nav-box">
  <h3 class="nav-box-title">{title}</h3>
  <div class="nav-box-content">
    {pilots.map(([pilotId, pilot]) => (
      <a href={`${baseUrl}pilots/${pilotId}`}>
        {pilot.first_name?.Key || pilot.id}
      </a>
    ))}
  </div>
</nav>

<style>
  .nav-box {
    border: 1px solid #ddd;
    padding: 8px;
    margin: 12px 0;
    background: #fff;
  }

  .nav-box-title {
    margin: 0 0 8px 0;
    font-size: 14px;
    font-weight: 600;
    color: #333;
  }

  .nav-box-content {
    display: block;
    width: 100%;
  }
  
  .nav-box-content a {
    display: block;
    color: #007bff;
    text-decoration: none;
    font-size: 13px;
    border-bottom: 1px solid #eee;
    padding: 4px 8px;
  }
  
  .nav-box-content a:hover {
    background: #f0f8ff;
    text-decoration: underline;
  }
  
  .nav-box-content a::before {
    content: "· ";
    color: #666;
  }
</style>
