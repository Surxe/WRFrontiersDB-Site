---
import { resolveLocalizationKey } from '../../utils/localization';
import LocalizedText from '../LocalizedText.astro';

// Get localized descriptions
const robotsDesc = resolveLocalizationKey('Robots_Description', 'Web_UI');
const aiBotsDesc = resolveLocalizationKey('AI_Bots_Description', 'Web_UI');
const factoryBotsDesc = resolveLocalizationKey('Factory_Bots_Description', 'Web_UI');
---

<nav>
  <div class="nav-box">
    <h3>Bots</h3>
    <ul>
      <li>
        <a href="/robots">Robots</a>
        <LocalizedText tag="p" localizationKey={robotsDesc} class="nav-description" />
      </li>
      <li>
        <a href="/ai_bots">AI Bots</a>
        <LocalizedText tag="p" localizationKey={aiBotsDesc} class="nav-description" />
      </li>
      <li>
        <a href="/factory_bots">Factory Bots</a>
        <LocalizedText tag="p" localizationKey={factoryBotsDesc} class="nav-description" />
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav-box {
    background-color: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
  }

  .nav-box h3 {
    margin: 0 0 1rem 0;
    color: #495057;
    font-size: 1.1rem;
  }

  .nav-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-box li {
    margin-bottom: 0.5rem;
  }

  .nav-box a {
    color: #007bff;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 0.25rem;
    display: block;
    transition: background-color 0.2s ease;
  }

  .nav-box a:hover {
    background-color: #e9ecef;
    color: #0056b3;
  }

  .nav-description {
    margin: 0.25rem 0 0 0.75rem;
    font-size: 0.875rem;
    color: #6c757d;
    line-height: 1.4;
    max-width: 300px;
  }
</style>
