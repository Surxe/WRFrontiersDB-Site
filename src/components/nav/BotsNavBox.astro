---
// Simple navbox for bot navigation
---

<nav>
  <div class="nav-box">
    <h3>Bots</h3>
    <ul>
      <li>
        <a href="/ai_bots">AI Bots</a>
      </li>
      <li>
        <a href="/factory_bots">Factory Bots</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav-box {
    background-color: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
  }

  .nav-box h3 {
    margin: 0 0 1rem 0;
    color: #495057;
    font-size: 1.1rem;
  }

  .nav-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-box li {
    margin-bottom: 0.5rem;
  }

  .nav-box a {
    color: #007bff;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 0.25rem;
    display: block;
    transition: background-color 0.2s ease;
  }

  .nav-box a:hover {
    background-color: #e9ecef;
    color: #0056b3;
  }
</style>
