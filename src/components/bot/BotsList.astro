---
import BotItem from './BotItem.astro';
import { refToId } from '../../utils/object_reference';
import { getDefaultString } from '../../utils/localization';

interface Props {
  presets: any[];
  modules: any;
  pilots: any;
}

const { presets, modules, pilots } = Astro.props;

// Helper function to get torso ID from preset
function getTorsoId(preset: any): string {
  if (!preset.modules) return getDefaultString({ en: 'Unknown' })!;

  // Find the torso module (typically in "Root" socket)
  const torsoModule = Object.values(preset.modules as any).find(
    (moduleInfo: any) => {
      if (
        !moduleInfo ||
        typeof moduleInfo !== 'object' ||
        !('module_ref' in moduleInfo)
      ) {
        return false;
      }
      const moduleId = refToId(moduleInfo.module_ref as string);
      const module = modules[moduleId];
      return (
        module &&
        module.module_type_ref &&
        module.module_type_ref.includes('Torso')
      );
    }
  );

  if (
    torsoModule &&
    typeof torsoModule === 'object' &&
    torsoModule !== null &&
    'module_ref' in torsoModule
  ) {
    const torsoId = refToId((torsoModule as any).module_ref as string);
    const torso = modules[torsoId];
    return getDefaultString(torso?.name)!;
  }

  return getDefaultString({ en: 'Unknown' })!;
}

// Group presets by character type, then by torso ID
const groupedPresets = presets.reduce(
  (groups, [id, preset]) => {
    const characterType =
      preset.character_type || getDefaultString({ en: 'Unknown' })!;
    const torsoId = getTorsoId(preset);

    if (!groups[characterType]) {
      groups[characterType] = {};
    }
    if (!groups[characterType][torsoId]) {
      groups[characterType][torsoId] = [];
    }
    groups[characterType][torsoId].push([id, preset]);
    return groups;
  },
  {} as Record<string, Record<string, any[]>>
);

// Sort groups by character type, then by torso ID
const sortedGroups = Object.keys(groupedPresets).sort();
---

<div class="bots-list">
  {
    sortedGroups.map((characterType) => (
      <div class="character-type-group">
        <h2 class="character-type-header">{characterType}</h2>
        {Object.keys(groupedPresets[characterType])
          .sort()
          .map((torsoId) => (
            <div class="torso-group">
              <h3 class="torso-header">{torsoId}</h3>
              <div class="bots-in-torso-group">
                {groupedPresets[characterType][torsoId].map((item: any) => (
                  <BotItem preset={item[1]} modules={modules} pilots={pilots} />
                ))}
              </div>
            </div>
          ))}
      </div>
    ))
  }
</div>

<style>
  .bots-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .character-type-group {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .character-type-header {
    font-size: 1.5rem;
    font-weight: 600;
    color: #333;
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #ddd;
  }

  .torso-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .torso-header {
    font-size: 1.2rem;
    font-weight: 500;
    color: #555;
    margin: 0;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid #eee;
  }

  .bots-in-torso-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-left: 1rem;
  }
</style>
