---
import type {
  CharacterPreset,
  CharacterPresetModule,
} from '../../types/character_preset';
import ObjRef from '../obj_ref/ObjRef.astro';
import LocalizedText from '../LocalizedText.astro';
import { refToId } from '../../utils/object_reference';
import {
  getModuleCategoryForWeaponSocket,
  isWeaponSocket,
} from '../../utils/socket_module_mapping';
import { getParseObject } from '../../utils/parse_object';

interface Props {
  preset: CharacterPreset;
  modules: any;
  pilots: any;
}

const { preset, modules, pilots } = Astro.props;

// Grouping and processing logic
function getProcessedData() {
  const modules_arr = preset.modules || [];

  // Shoulder distinctness identification removed since module names now contain Left/Right information

  // Track unique weapon IDs to decide on group name visibility
  const weaponIds = new Set<string>();
  modules_arr.forEach((m) => {
    if (isWeaponSocket(m.socket_name)) {
      weaponIds.add(refToId(m.module_ref));
    }
  });
  const shouldShowWeaponGroups = weaponIds.size > 1;

  // Grouping logic
  interface ModuleGroupEntry {
    module: any;
    count: number;
    firstIndex: number;
    moduleCategoryName?: any;
    level: number;
  }
  const groups = new Map<string, ModuleGroupEntry>();

  modules_arr.forEach((entry: CharacterPresetModule, idx) => {
    const moduleId = refToId(entry.module_ref);
    const module = modules[moduleId];
    if (!module) return;

    // Determine grouping key
    const isWeapon = isWeaponSocket(entry.socket_name);
    const mCategoryId = isWeapon
      ? getModuleCategoryForWeaponSocket(entry.socket_name)
      : undefined;

    // Group weapons by module_ref, but separate by category (Shoulder/Torso) if we are showing groups
    const weaponCategorySuffix =
      isWeapon && shouldShowWeaponGroups && mCategoryId
        ? `|${mCategoryId}`
        : '';

    // Shoulders are grouped if they are the same
    const isShoulderSlot =
      entry.socket_name === 'Shoulder_L' || entry.socket_name === 'Shoulder_R';

    const key =
      isWeapon || isShoulderSlot
        ? `${entry.module_ref}${weaponCategorySuffix}`
        : `${entry.module_ref}|${entry.socket_name}`;

    // Calculate module category name if needed
    let moduleCategoryName: any;
    if (isWeapon && shouldShowWeaponGroups) {
      const moduleCategoryID = getModuleCategoryForWeaponSocket(
        entry.socket_name
      );
      if (moduleCategoryID) {
        const moduleCategory = getParseObject(
          moduleCategoryID,
          'Objects/ModuleCategory.json'
        );
        moduleCategoryName = moduleCategory.name;
      }
    }

    if (groups.has(key)) {
      groups.get(key)!.count++;
    } else {
      groups.set(key, {
        module,
        count: 1,
        firstIndex: idx,
        moduleCategoryName,
        level: entry.level,
      });
    }
  });

  return {
    grouped: Array.from(groups.values()).sort(
      (a, b) => a.firstIndex - b.firstIndex
    ),
    shouldShowWeaponGroups,
  };
}

const { grouped } = getProcessedData();
---

<tr class="bot-row">
  <td class="bot-name">
    <ObjRef obj={preset} iconSize={32} />
  </td>
  <td class="bot-pilot">
    {
      preset.pilot ? (
        <>
          <ObjRef obj={pilots[refToId(preset.pilot.pilot_ref)]} iconSize={24}/>
          {preset.pilot.level && <span class="pilot-level">Lvl {preset.pilot.level}</span>}
        </>
      ) : (
        <span class="no-pilot">-</span>
      )
    }
  </td>
  <td class="bot-modules">
    <div class="modules-list">
      {
        grouped.map(({ module, count, moduleCategoryName, level }) => {
          return (
            <span class="module-item">
              <ObjRef obj={module} />
              <span class="level">Lvl {level}</span>
              {moduleCategoryName && (
                <span class="module-group">
                  (
                  <LocalizedText
                    tag="span"
                    localizationKey={moduleCategoryName}
                  />
                  )
                </span>
              )}
              {count > 1 && <span class="module-count">x{count}</span>}
            </span>
          );
        })
      }
    </div>
  </td>
</tr>

<style>
  .bot-row {
    border-bottom: 1px solid #eee;
  }

  .bot-row:hover {
    background-color: #f8f9fa;
  }

  .bot-name {
    padding: 0.75rem;
    font-weight: 500;
    vertical-align: middle;
  }

  .bot-pilot {
    padding: 0.75rem;
    text-align: center;
    vertical-align: middle;
  }

  .no-pilot {
    color: #999;
    font-style: italic;
  }

  .bot-modules {
    padding: 0.75rem;
    vertical-align: middle;
  }

  .modules-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .module-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .module-group {
    color: #666;
    font-size: 0.8rem;
  }

  .module-count {
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .level {
    color: #666;
    font-size: 0.8rem;
  }
</style>
