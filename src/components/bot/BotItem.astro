---
import type {
  CharacterPreset,
  CharacterPresetModule,
} from '../../types/character_preset';
import ObjRef from '../obj_ref/ObjRef.astro';
import { refToId } from '../../utils/object_reference';
import {
  getModuleGroupForWeaponSocket,
  isWeaponSocket,
} from '../../utils/socket_module_mapping';
import { getSocketSideLocaleKey } from '../../utils/socket_side_mapping';
import {
  getDefaultString,
  resolveLocalizationKey,
} from '../../utils/localization';
import { getParseObject } from '../../utils/parse_object';

interface Props {
  preset: CharacterPreset;
  modules: any;
  pilots: any;
}

const { preset, modules, pilots } = Astro.props;

// Grouping and processing logic
function getProcessedData() {
  const modules_arr = preset.modules || [];

  // Identify shoulder distinctness
  const shoulderL = modules_arr.find((e) => e.socket_name === 'Shoulder_L');
  const shoulderR = modules_arr.find((e) => e.socket_name === 'Shoulder_R');
  const hasDifferentShoulders =
    shoulderL && shoulderR && shoulderL.module_ref !== shoulderR.module_ref;

  // Track unique weapon IDs to decide on group name visibility
  const weaponIds = new Set<string>();
  modules_arr.forEach((m) => {
    if (isWeaponSocket(m.socket_name)) {
      weaponIds.add(refToId(m.module_ref));
    }
  });
  const shouldShowWeaponGroups = weaponIds.size > 1;

  // Grouping logic
  interface ModuleGroupEntry {
    module: any;
    entry: CharacterPresetModule;
    count: number;
    firstIndex: number;
  }
  const groups = new Map<string, ModuleGroupEntry>();

  modules_arr.forEach((entry, idx) => {
    const moduleId = refToId(entry.module_ref);
    const module = modules[moduleId];
    if (!module) return;

    // Determine grouping key
    const isWeapon = isWeaponSocket(entry.socket_name);
    const mGroupId = isWeapon
      ? getModuleGroupForWeaponSocket(entry.socket_name)
      : undefined;

    // Group weapons by module_ref, but separate by group (Shoulder/Torso) if we are showing groups
    const weaponGroupSuffix =
      isWeapon && shouldShowWeaponGroups && mGroupId ? `|${mGroupId}` : '';

    // Shoulders are grouped if they are the same
    const isShoulderSlot =
      entry.socket_name === 'Shoulder_L' || entry.socket_name === 'Shoulder_R';

    const key =
      isWeapon || isShoulderSlot
        ? `${entry.module_ref}${weaponGroupSuffix}`
        : `${entry.module_ref}|${entry.socket_name}`;

    if (groups.has(key)) {
      groups.get(key)!.count++;
    } else {
      groups.set(key, { module, entry, count: 1, firstIndex: idx });
    }
  });

  return {
    grouped: Array.from(groups.values()).sort(
      (a, b) => a.firstIndex - b.firstIndex
    ),
    shouldShowWeaponGroups,
    hasDifferentShoulders,
  };
}

const { grouped, shouldShowWeaponGroups, hasDifferentShoulders } =
  getProcessedData();

// Helper to get group name (Shoulder/Torso)
function getModuleGroupName(groupId: string): string {
  try {
    const group = getParseObject(groupId, 'Objects/ModuleGroup.json');
    return getDefaultString(group.name) || groupId;
  } catch {
    return groupId;
  }
}
---

<tr class="bot-row">
  <td class="bot-name">
    <ObjRef obj={preset} iconSize={32} />
  </td>
  <td class="bot-pilot">
    {
      preset.pilot_ref ? (
        <ObjRef obj={pilots[refToId(preset.pilot_ref)]} iconSize={24} />
      ) : (
        <span class="no-pilot">-</span>
      )
    }
  </td>
  <td class="bot-modules">
    <div class="modules-list">
      {
        grouped.map(({ module, entry, count }) => {
          const isWeapon = isWeaponSocket(entry.socket_name);
          const isShoulderSlot =
            entry.socket_name === 'Shoulder_L' ||
            entry.socket_name === 'Shoulder_R';

          let socketSideLabel = undefined;
          if (isShoulderSlot && hasDifferentShoulders) {
            const sideLocaleKey = getSocketSideLocaleKey(entry.socket_name);
            if (sideLocaleKey) {
              const localizationKey = resolveLocalizationKey(
                sideLocaleKey,
                'Web_UI'
              );
              socketSideLabel = getDefaultString(localizationKey);
            }
          }

          const moduleGroup = isWeapon
            ? getModuleGroupForWeaponSocket(entry.socket_name)
            : undefined;
          const moduleGroupName =
            isWeapon && shouldShowWeaponGroups && moduleGroup
              ? getModuleGroupName(moduleGroup)
              : undefined;

          return (
            <span class="module-item">
              <ObjRef obj={module} />
              {socketSideLabel && (
                <span class="socket-side">({socketSideLabel})</span>
              )}
              {moduleGroupName && (
                <span class="module-group">({moduleGroupName})</span>
              )}
              {count > 1 && !socketSideLabel && (
                <span class="module-count">x{count}</span>
              )}
            </span>
          );
        })
      }
    </div>
  </td>
</tr>

<style>
  .bot-row {
    border-bottom: 1px solid #eee;
  }

  .bot-row:hover {
    background-color: #f8f9fa;
  }

  .bot-name {
    padding: 0.75rem;
    font-weight: 500;
    vertical-align: middle;
  }

  .bot-pilot {
    padding: 0.75rem;
    text-align: center;
    vertical-align: middle;
  }

  .no-pilot {
    color: #999;
    font-style: italic;
  }

  .bot-modules {
    padding: 0.75rem;
    vertical-align: middle;
  }

  .modules-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .module-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .module-group {
    color: #666;
    font-size: 0.8rem;
  }

  .socket-side {
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .module-count {
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
  }
</style>
