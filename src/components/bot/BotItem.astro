---
import ObjRef from '../obj_ref/ObjRef.astro';
import { refToId } from '../../utils/object_reference';
import {
  getModuleGroupForWeaponSocket,
  isWeaponSocket,
} from '../../utils/socket_module_mapping';
import { MODULE_GROUPS } from '../../utils/module_group_mapping';
import { getSocketSideLocaleKey } from '../../utils/socket_side_mapping';
import { getDefaultString, resolveLocalizationKey } from '../../utils/localization';

interface Props {
  preset: any;
  modules: any;
  pilots: any;
}

const { preset, modules, pilots } = Astro.props;

// Helper function to get module group name
function getModuleGroupName(groupId: string): string {
  return (
    MODULE_GROUPS[groupId as keyof typeof MODULE_GROUPS]?.name?.en || groupId
  );
}

// Check if there are different weapon IDs across preset
function hasDifferentWeaponIds(): boolean {
  const weaponIds = new Set<string>();

  Object.entries(preset.modules as any).forEach(
    ([socketName, moduleInfo]: [string, any]) => {
      if (isWeaponSocket(socketName)) {
        const moduleId = refToId(moduleInfo.module_ref as string);
        weaponIds.add(moduleId);
      }
    }
  );

  return weaponIds.size > 1;
}

// Check if there are different shoulder module IDs across preset
function hasDifferentShoulderModuleIds(): boolean {
  const shoulderModuleIds = new Set<string>();

  Object.entries(preset.modules as any).forEach(
    ([socketName, moduleInfo]: [string, any]) => {
      if (socketName === 'Shoulder_L' || socketName === 'Shoulder_R') {
        const moduleId = refToId(moduleInfo.module_ref as string);
        shoulderModuleIds.add(moduleId);
      }
    }
  );

  return shoulderModuleIds.size > 1;
}

// Define desired socket order
const SOCKET_ORDER = [
  'Root',
  'None',
  'Shoulder_L',
  'Shoulder_R',
  'Ability',
  'UltAbility',
];

// Group modules by their module reference and parent socket
function getGroupedModules() {
  const moduleGroups = new Map<
    string,
    {
      module: any;
      socketName: string;
      moduleInfo: any;
      count: number;
      socketOrder: number;
      shoulderCount: number;
    }
  >();

  Object.entries(preset.modules as any).forEach(
    ([socketName, moduleInfo]: [string, any]) => {
      const moduleId = refToId(moduleInfo.module_ref as string);
      const module = modules[moduleId];
      if (!module) {
        return;
      }

      // For weapons and shoulder modules, group by module reference only
      // For other modules, group by module reference and parent socket
      const isWeapon = isWeaponSocket(socketName);
      const isShoulderModule = socketName === 'Shoulder_L' || socketName === 'Shoulder_R';
      const key = (isWeapon || isShoulderModule)
        ? moduleInfo.module_ref
        : `${moduleInfo.module_ref}|${moduleInfo.parent_socket_name || 'none'}`;

      // Determine socket order for sorting
      const socketOrderIndex = SOCKET_ORDER.indexOf(socketName);
      const socketOrder =
        socketOrderIndex !== -1 ? socketOrderIndex : SOCKET_ORDER.length;

      if (moduleGroups.has(key)) {
        // Increment count if already exists
        const existing = moduleGroups.get(key)!;
        existing.count += 1;
        // Track shoulder count separately - check if this is a shoulder weapon
        const isShoulderWeapon = isWeapon && (
          moduleInfo.parent_socket_name === 'Shoulder_L' || 
          moduleInfo.parent_socket_name === 'Shoulder_R'
        );
        if (isShoulderWeapon) {
          existing.shoulderCount += 1;
        }
        // Use the earliest socket order for the group
        existing.socketOrder = Math.min(existing.socketOrder, socketOrder);
      } else {
        // Add new entry with initial count and socket order
        const isShoulderWeapon = isWeapon && (
          moduleInfo.parent_socket_name === 'Shoulder_L' || 
          moduleInfo.parent_socket_name === 'Shoulder_R'
        );
        const shoulderCount = isShoulderWeapon ? 1 : 0;
        moduleGroups.set(key, {
          module,
          socketName,
          moduleInfo,
          count: 1,
          socketOrder,
          shoulderCount,
        });
      }
    }
  );

  // Convert to array and apply shoulder multiplier, then sort
  return Array.from(moduleGroups.values()).map((group) => {
    // If this is a shoulder weapon, check if it should be doubled
    if (group.shoulderCount > 0) {
      // For Titans, shoulder weapons are implicitly dual-mounted
      // Check if this is a Titan and the weapon is a shoulder weapon
      const isTitan = preset.character_type === 'Titan';
      const isShoulderWeapon = isWeaponSocket(group.socketName);
      
      if (isTitan && isShoulderWeapon) {
        // Titan shoulder weapons are always dual-mounted, so multiply by 2
        return {
          ...group,
          count: group.count * 2
        };
      } else if (group.shoulderCount === 2) {
        // For non-Titans, only double if explicitly has both shoulders
        return {
          ...group,
          count: group.count * 2
        };
      }
    }
    return group;
  }).sort((a, b) => {
    // First sort by socket order
    if (a.socketOrder !== b.socketOrder) {
      return a.socketOrder - b.socketOrder;
    }
    // Then sort by socket name for consistent ordering within the same order
    return a.socketName.localeCompare(b.socketName);
  });
}

const shouldShowWeaponGroups = hasDifferentWeaponIds();
const groupedModules = getGroupedModules();
---

<tr class="bot-row">
  <td class="bot-name">
    <ObjRef obj={preset} iconSize={32} />
  </td>
  <td class="bot-pilot">
    {
      preset.pilot_ref ? (
        <ObjRef obj={pilots[refToId(preset.pilot_ref)]} iconSize={24} />
      ) : (
        <span class="no-pilot">-</span>
      )
    }
  </td>
  <td class="bot-modules">
    <div class="modules-list">
      {
        groupedModules.map(({ module, socketName, moduleInfo, count }) => {
          // Only show module group info for weapons and only when there are different weapon IDs
          const isWeapon = isWeaponSocket(socketName);
          const parentSocket = moduleInfo.parent_socket_name;
          const moduleGroup =
            isWeapon && parentSocket
              ? getModuleGroupForWeaponSocket(socketName)
              : undefined;
          const moduleGroupName =
            isWeapon && shouldShowWeaponGroups && moduleGroup
              ? getModuleGroupName(moduleGroup)
              : undefined;

          // For Titan weapons with different IDs, show Left/Right labels
          // For Titan shoulder modules with different IDs, show Left/Right labels
          let socketSideLabel = undefined;
          const isShoulderModule = socketName === 'Shoulder_L' || socketName === 'Shoulder_R';
          
          if (preset.character_type === 'Titan') {
            if (isWeapon && hasDifferentWeaponIds()) {
              const sideLocaleKey = getSocketSideLocaleKey(socketName);
              if (sideLocaleKey) {
                const localizationKey = resolveLocalizationKey(sideLocaleKey, 'Web_UI');
                socketSideLabel = getDefaultString(localizationKey);
              }
            } else if (isShoulderModule && hasDifferentShoulderModuleIds()) {
              const sideLocaleKey = getSocketSideLocaleKey(socketName);
              if (sideLocaleKey) {
                const localizationKey = resolveLocalizationKey(sideLocaleKey, 'Web_UI');
                socketSideLabel = getDefaultString(localizationKey);
              }
            }
          }

          return (
            <span class="module-item">
              <ObjRef obj={module} />
              {socketSideLabel && (
                <span class="socket-side">
                  ({socketSideLabel})
                </span>
              )}
              {moduleGroupName && (
                <span class="module-group">
                  ({moduleGroupName})
                </span>
              )}
              {count > 1 && !socketSideLabel && (
                <span class="module-count">
                  x{count}
                </span>
              )}
            </span>
          );
        })
      }
    </div>
  </td>
</tr>

<style>
  .bot-row {
    border-bottom: 1px solid #eee;
  }

  .bot-row:hover {
    background-color: #f8f9fa;
  }

  .bot-name {
    padding: 0.75rem;
    font-weight: 500;
    vertical-align: middle;
  }

  .bot-pilot {
    padding: 0.75rem;
    text-align: center;
    vertical-align: middle;
  }

  .no-pilot {
    color: #999;
    font-style: italic;
  }

  .bot-modules {
    padding: 0.75rem;
    vertical-align: middle;
  }

  .modules-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .module-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .module-group {
    color: #666;
    font-size: 0.8rem;
  }

  .socket-side {
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .module-count {
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
  }
</style>
