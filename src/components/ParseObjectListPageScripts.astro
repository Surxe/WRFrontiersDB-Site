---
export interface Props {
  jsFileName?: string;
}

const { jsFileName } = Astro.props;
---

<!--Common astro scripts for all ParseObjectList pages--><!--Initialize localization on all the localizeable elements-->
<script type="module">
  const localizationModule = await import('/js/localization.js');
  const { initializeLocalization } = localizationModule;
  initializeLocalization('current');
</script>

<!--Load the specific JS file for this list page, only if jsFileName is provided-->{
  jsFileName && <script is:inline src={`/js/${jsFileName}`} />
}
