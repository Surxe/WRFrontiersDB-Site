---
import PresetItem from './PresetItem.astro';

interface Props {
  presets: any[];
  modules: any;
  pilots: any;
}

const { presets, modules, pilots } = Astro.props;

// Group presets by character type
const groupedPresets = presets.reduce(
  (groups, [_id, preset]) => {
    const characterType = preset.character_type || 'Unknown';
    if (!groups[characterType]) {
      groups[characterType] = [];
    }
    groups[characterType].push([_id, preset]);
    return groups;
  },
  {} as Record<string, any[]>
);

// Sort groups by character type
const sortedGroups = Object.keys(groupedPresets).sort();
---

<div class="presets-list">
  {
    sortedGroups.map((characterType) => (
      <div class="character-type-group">
        <h2 class="character-type-header">{characterType}</h2>
        <div class="presets-in-group">
          {groupedPresets[characterType].map(([_id, preset]) => (
            <PresetItem preset={preset} modules={modules} pilots={pilots} />
          ))}
        </div>
      </div>
    ))
  }
</div>

<style>
  .presets-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .character-type-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .character-type-header {
    font-size: 1.5rem;
    font-weight: 600;
    color: #333;
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #ddd;
  }

  .presets-in-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
