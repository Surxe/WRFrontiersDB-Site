---
import ObjRef from '../obj_ref/ObjRef.astro';
import { refToId } from '../../utils/object_reference';
import { getModuleGroupForWeaponSocket, isWeaponSocket } from '../../utils/socket_module_mapping';
import { MODULE_GROUPS } from '../../utils/module_group_mapping';

interface Props {
  preset: any;
  modules: any;
  pilots: any;
}

const { preset, modules, pilots } = Astro.props;

// Helper function to get module group name
function getModuleGroupName(groupId: string): string {
  return MODULE_GROUPS[groupId as keyof typeof MODULE_GROUPS]?.name?.en || groupId;
}

// Check if there are different weapon IDs across preset
function hasDifferentWeaponIds(): boolean {
  const weaponIds = new Set<string>();
  
  Object.entries(preset.modules as any).forEach(([socketName, moduleInfo]: [string, any]) => {
    if (isWeaponSocket(socketName)) {
      const moduleId = refToId(moduleInfo.module_ref as string);
      weaponIds.add(moduleId);
    }
  });
  
  return weaponIds.size > 1;
}

// Group modules by their module reference and parent socket
function getGroupedModules() {
  const moduleGroups = new Map<string, {
    module: any;
    socketName: string;
    moduleInfo: any;
    count: number;
  }>();

  Object.entries(preset.modules as any).forEach(([socketName, moduleInfo]: [string, any]) => {
    const moduleId = refToId(moduleInfo.module_ref as string);
    const module = modules[moduleId];
    if (!module) {
      return;
    }

    // Create a unique key based on module reference and parent socket
    const key = `${moduleInfo.module_ref}|${moduleInfo.parent_socket_name || 'none'}`;
    
    if (moduleGroups.has(key)) {
      // Increment count if already exists
      const existing = moduleGroups.get(key)!;
      existing.count++;
    } else {
      // Determine initial count - always start with 1 for each entry
      const initialCount = 1;
      
      // Add new entry
      moduleGroups.set(key, {
        module,
        socketName,
        moduleInfo,
        count: initialCount
      });
    }
  });

  // Convert to array and apply shoulder weapon multiplier
  return Array.from(moduleGroups.values()).map((group) => {
    // If this is a shoulder weapon with parent_socket_name "Shoulder_R", 
    // multiply the count by 2 (for both shoulders)
    if (isWeaponSocket(group.socketName) && group.moduleInfo.parent_socket_name === 'Shoulder_R') {
      return {
        ...group,
        count: group.count * 2
      };
    }
    
    return group;
  });
}

const shouldShowWeaponGroups = hasDifferentWeaponIds();
const groupedModules = getGroupedModules();

---

<div class="preset-item">
  <ObjRef obj={preset} iconSize={48} />
  {
    preset.pilot_ref && (
      <p>
        Pilot:
        {(() => {
          const pilotId = refToId(preset.pilot_ref as string);
          const pilot = pilots[pilotId];
          return pilot ? (
            <ObjRef obj={pilot} />
          ) : (
            preset.pilot_ref
          );
        })()}
      </p>
    )
  }
  <div class="modules-list">
    <strong>Modules:</strong>
    {
      groupedModules.map(({
        module,
        socketName,
        moduleInfo,
        count
      }) => {
        // Only show module group info for weapons and only when there are different weapon IDs
        const isWeapon = isWeaponSocket(socketName);
        const parentSocket = moduleInfo.parent_socket_name;
        const moduleGroup = isWeapon && parentSocket ? getModuleGroupForWeaponSocket(socketName) : undefined;
        const moduleGroupName = shouldShowWeaponGroups && moduleGroup ? getModuleGroupName(moduleGroup) : undefined;

        return (
          <span style="margin-right: 0.5rem;">
            <ObjRef obj={module} />
            {moduleGroupName && (
              <span style="margin-left: 0.25rem; color: #666; font-size: 0.85rem;">
                ({moduleGroupName})
              </span>
            )}
            {count > 1 && (
              <span style="margin-left: 0.25rem; color: #666; font-size: 0.85rem;">
                x{count}
              </span>
            )}
          </span>
        );
      })
    }
  </div>
</div>

<style>
  .preset-item {
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #f9f9f9;
  }

  .preset-item p {
    margin: 0.25rem 0;
    color: #666;
  }

  .modules-list {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .modules-list strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #333;
  }
</style>
