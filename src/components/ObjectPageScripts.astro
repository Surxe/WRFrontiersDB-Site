---
export interface Props {
  objectData: any;
  jsFileName?: string;
  slug?: string;
}

const { objectData, jsFileName, slug } = Astro.props;

// Store complete object data with slug for browser access
const browserData = {
  ...objectData,
  slug: slug,
};
---

<!--Common astro scripts for all ParseObject pages--><!--The object's data, for use by js-->
<script
  type="application/json"
  id="object-data"
  set:text={JSON.stringify(objectData)}
/>

<!--Complete object data with slug for browser access-->
<script
  type="application/json"
  id="browser-data"
  set:text={JSON.stringify(browserData)}
/>

<!--Initialize localization on all the localizeable elements-->
<script type="module">
  const localizationModule = await import('/js/localization.js');
  const { initializeLocalization } = localizationModule;
  initializeLocalization('current');
</script>

<!--Load the specific JS file for this object page, only if jsFileName is provided-->{
  jsFileName && <script is:inline src={`/js/${jsFileName}`} />
}
