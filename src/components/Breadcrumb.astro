---
import type { BreadcrumbTrail } from '../types/breadcrumb';
import { getDefaultString } from '../utils/localization';

interface Props {
  breadcrumbs: BreadcrumbTrail;
}

const { breadcrumbs } = Astro.props;
---

<nav class="breadcrumb">
  {
    breadcrumbs.map((breadcrumb, index) => (
      <span>
        {breadcrumb.href ? (
          <a href={breadcrumb.href}>
            {typeof breadcrumb.label === 'string' ? (
              breadcrumb.label
            ) : (
              <>
                {breadcrumb.label.InvariantString || (
                  <span
                    data-loc-key={breadcrumb.label.Key}
                    data-loc-namespace={breadcrumb.label.TableNamespace}
                  >
                    {getDefaultString(breadcrumb.label)}
                  </span>
                )}
              </>
            )}
          </a>
        ) : (
          <span class="current">
            {typeof breadcrumb.label === 'string' ? (
              breadcrumb.label
            ) : (
              <>
                {breadcrumb.label.InvariantString || (
                  <span
                    data-loc-key={breadcrumb.label.Key}
                    data-loc-namespace={breadcrumb.label.TableNamespace}
                  >
                    {getDefaultString(breadcrumb.label)}
                  </span>
                )}
              </>
            )}
          </span>
        )}
        {index < breadcrumbs.length - 1 && (
          <span class="separator"> &gt; </span>
        )}
      </span>
    ))
  }
</nav>

<style>
  .breadcrumb {
    margin: 8px 0;
    font-size: 14px;
  }

  .breadcrumb a {
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .current {
    font-weight: 500;
  }

  .breadcrumb .separator {
    margin: 0 4px;
  }
</style>
