---
import Page from './Page.astro';
import ParseObjectListPageScripts from './ParseObjectListPageScripts.astro';
import type { LocalizationKey } from '../types/localization';

export interface Props {
  title?: string | LocalizationKey | LocalizationKey[];
  description?: string;
  metaImage?: string;
  url?: string;
  type?: string;
  jsFileName?: string;
  headerImage?: string;
}

const { title, description, metaImage, url, type, jsFileName, headerImage } =
  Astro.props;

// Basic page layout for ParseObjectList pages, e.g. pages/modules.astro
---

<Page
  title={title}
  description={description}
  metaImage={metaImage}
  url={url}
  type={type}
  headerImage={headerImage}
>
  <slot name="head" slot="head" />
  <slot />

  {(<ParseObjectListPageScripts jsFileName={jsFileName} />)}
</Page>
