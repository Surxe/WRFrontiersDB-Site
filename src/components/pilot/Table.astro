---
import TalentRow from './TalentRow.astro';
import TalentTypeRow from './TalentTypeRow.astro';
import type { Pilot, PilotTalent, PilotTalentType } from '../../types/pilot';

interface Props {
  tableClass: string;
  pilots: [string, Pilot][];
  pilotTalents?: Record<string, PilotTalent>;
  pilotTalentTypes?: Record<string, PilotTalentType>;
  fullOrOnHover?: 'full' | 'onHover' | undefined;
}

// if pilotTalents is provided, use TalentRow
// if pilotTalentTypes is provided, use TalentTypeRow
// otherwise, throw error

const { tableClass, pilots, pilotTalents, pilotTalentTypes, fullOrOnHover } =
  Astro.props;

// Validate that at least one of the required props is provided
if (!pilotTalents && !pilotTalentTypes) {
  throw new Error('Either pilotTalents or pilotTalentTypes must be provided');
}
if (pilotTalents && pilotTalentTypes) {
  throw new Error(
    'Only one of pilotTalents or pilotTalentTypes can be provided'
  );
}

// Pre-calculate maxTalents for each pilot to avoid redundant calculations
const pilotsWithMaxTalents = pilots.map(([id, pilot]) => {
  const maxTalents = Math.max(
    ...pilot.levels.map((level) => level?.talents_refs?.length || 0)
  );
  return [id, pilot, maxTalents] as const;
});
---

<table class={tableClass}>
  <thead>
    <tr>
      <th>Pilot Name</th>
      <th>Level 1</th>
      <th>Level 2</th>
      <th>Level 3</th>
      <th>Level 4</th>
      <th>Level 5</th>
    </tr>
  </thead>
  <tbody>
    {
      pilotsWithMaxTalents.map(([_id, pilot, maxTalents]) => (
        <>
          {pilotTalents ? (
            <TalentRow
              pilot={pilot}
              maxTalents={maxTalents}
              pilotTalents={pilotTalents}
              fullOrOnHover={fullOrOnHover}
            />
          ) : (
            <TalentTypeRow
              pilot={pilot}
              maxTalents={maxTalents}
              pilotTalentTypes={pilotTalentTypes!}
            />
          )}
        </>
      ))
    }
  </tbody>
</table>
