---
import PilotTable from './PilotsPageTable.astro';
import { getParseObjects } from '../../utils/parse_object';
import { prepareObjectList, groupBy, sortGroups } from '../../utils/list';
import { resolveObjectRef } from '../../utils/object_resolver';
import { refToId } from '../../utils/object_reference';
import type {
  Pilot,
  PilotType,
  PilotTalent,
  PilotTalentType,
} from '../../types/pilot';
import ObjRef from '../obj_ref/ObjRef.astro';

interface Props {
  pilots: Record<string, Pilot>;
}

const { pilots } = Astro.props;

// Load pilot types, and pilot talents
const pilotTypes = getParseObjects<PilotType>('Objects/PilotType.json');
const pilotTalents = getParseObjects<PilotTalent>('Objects/PilotTalent.json');
const pilotTalentTypes = getParseObjects<PilotTalentType>(
  'Objects/PilotTalentType.json'
);
const rarities = getParseObjects('Objects/Rarity.json');

// Prepare and filter pilots
const entries = prepareObjectList(pilots, { prodReadyOnly: false });

// Group by pilot type
const grouped = groupBy(entries, ([_, pilot]) => refToId(pilot.pilot_type_ref));

// Define explicit sort order for pilot types
const pilotTypeOrder: Record<string, number> = {
  'DA_PilotType_Legendary.0': 1,
  'DA_PilotType_Common.0': 2,
};

// Sort groups with explicit order: Legendary before Common
const sortedGroups = sortGroups(grouped, (a, b) => {
  const orderA = pilotTypeOrder[a] || 999;
  const orderB = pilotTypeOrder[b] || 999;
  return orderA - orderB;
});
---

<!-- 
Create tables. Levels 1 through 4 may have multiple talents in them, so 
the other columns have rowspan to center them within their group of rows
-->{
  sortedGroups.map(([pilotTypeId, pilotEntries]) => (
    <section>
      <h2>
        {(() => {
          const pilotType = pilotTypes[pilotTypeId];
          if (!pilotType) {
            return <span>Unknown Pilot Type: {pilotTypeId}</span>;
          }
          const rarity = resolveObjectRef(pilotType.rarity_ref, rarities);
          return rarity ? (
            <ObjRef obj={rarity} useHref={false} />
          ) : (
            <span>Unknown Rarity</span>
          );
        })()}
      </h2>
      <PilotTable
        tableClass="pilots-table-pilot-talent-hover"
        pilots={pilotEntries}
        pilotTalents={pilotTalents}
        fullOrOnHover="onHover"
      />
      <PilotTable
        tableClass="pilots-table-pilot-talent-full"
        pilots={pilotEntries}
        pilotTalents={pilotTalents}
        fullOrOnHover="full"
      />
      <PilotTable
        tableClass="pilots-table-pilot-talent-type"
        pilots={pilotEntries}
        pilotTalentTypes={pilotTalentTypes}
      />
    </section>
  ))
}
