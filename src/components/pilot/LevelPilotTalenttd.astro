---
import TalentCell from './TalentCell.astro';
import type { PilotTalent } from '../../types/pilot';
import type { ModuleStat } from '../../types/module';
import { getParseObjects } from '../../utils/parse_object';
import { getStatValueChoices } from '../../utils/stat';

interface Props {
  levelIndex: number; // 0 for level 1, 1 for level 2, 2 for level 3, 3 for level 4, 4 for level 5
  level: {
    talents_refs: string[];
    talent_type_ref: string;
  };
  talentIndex: number;
  maxTalents: number;
  pilotTalents: Record<string, PilotTalent>;
  version: string;
  fullOrOnHover?: 'full' | 'onHover';
}

/*
Create table data cells that look like this for the respective levels:
Level 1-4:
Talent1
Talent2
Talent3

Level 5: 
Talent1 (rowspan=maxTalents)

To summarize: Levels 1-4 have 3 talents, level 5 has 1 talent. 
*/

const {
  levelIndex,
  level,
  talentIndex,
  maxTalents,
  pilotTalents,
  version,
  fullOrOnHover = 'full',
} = Astro.props;

if (fullOrOnHover !== 'full' && fullOrOnHover !== 'onHover') {
  throw new Error('fullOrOnHover must be "full" or "onHover"');
}

// Load ModuleStats for stat replacements
const moduleStats = getParseObjects<ModuleStat>(
  'Objects/ModuleStat.json',
  version
);

// For level 5, always use the first talent; for others, use the current talentIndex
// because level 5 only has one talent slot
const getTalentData = (levelIdx: number, talentIdx: number) => {
  const rawTalentId =
    levelIdx === 4 ? level.talents_refs[0] : level.talents_refs[talentIdx];

  const talent = pilotTalents[rawTalentId];
  if (!talent) {
    throw new Error(
      `Talent "${rawTalentId}" not found in pilotTalents. Available: ${Object.keys(pilotTalents).slice(0, 10).join(', ')}`
    );
  }

  // Defensive: Check if talent has stats array
  if (
    !talent.stats ||
    !Array.isArray(talent.stats) ||
    talent.stats.length === 0
  ) {
    return {
      talent: {
        id: talent.id,
        name: talent.name?.Key || 'No name',
        description: talent.description?.Key || 'No description',
        stats: [],
        ui_description: talent.ui_description?.Key || 'No UI description',
        short_ui_description:
          talent.short_ui_description?.Key || 'No short UI description',
      },
      statValueChoices: {},
    };
  }

  const statValueChoices = getStatValueChoices(talent.stats, moduleStats);
  return { talent, statValueChoices };
};

// Pre-compute rendering logic
const shouldRender = levelIndex === 4 ? talentIndex === 0 : true;
const rowspan = levelIndex === 4 ? maxTalents : undefined;
const talentData = shouldRender ? getTalentData(levelIndex, talentIndex) : null;
---

{/* Talent column */}
{/* For level 5, use rowspan and only render on first talent row */}
{/* For levels 1 and 2-4, render for each talent index */}
{
  shouldRender && talentData && talentData.talent && (
    <TalentCell
      talent={talentData.talent}
      version={version}
      statValueChoices={talentData.statValueChoices}
      fullOrOnHover={fullOrOnHover}
      rowspan={rowspan}
    />
  )
}
