---
import TalentPilotRow from './TalentPilotRow.astro';
import type {
  Pilot,
  PilotTalent,
  PilotWithTalentInfo,
} from '../../types/pilot';
import { refToId } from '../../utils/object_reference';

interface Props {
  pilotsWithThisTalent: PilotWithTalentInfo[];
  allPilotTalents: Record<string, PilotTalent>;
  allPilots: Record<string, Pilot>;
  currentTalentId: string;
  currentTalentLevel?: number;
  tableClass?: string;
  fullOrOnHover?: 'full' | 'onHover';
}

const {
  pilotsWithThisTalent,
  allPilotTalents,
  allPilots,
  currentTalentId,
  currentTalentLevel,
  tableClass = 'pilots-with-talent-table',
  fullOrOnHover = 'full',
} = Astro.props;

// Handle empty state
if (pilotsWithThisTalent.length === 0) {
  return null;
}

// Pre-calculate maxTalents for each pilot
const pilotsWithMaxTalents = pilotsWithThisTalent
  .map(({ pilot_ref, talent_index }) => {
    const pilotId = refToId(pilot_ref);
    const pilot = allPilots[pilotId];

    let maxTalents = 1;
    if (pilot && pilot.levels) {
      maxTalents = Math.max(
        ...pilot.levels.map((level) => level?.talents_refs?.length || 0)
      );
    }

    return { pilot, level: currentTalentLevel || 1, talent_index, maxTalents };
  })
  .filter((p) => p.pilot); // Filter out missing pilots just in case
---

<table class={tableClass}>
  <thead>
    <tr>
      <th>Pilot Name</th>
      <th>Level 1</th>
      <th>Level 2</th>
      <th>Level 3</th>
      <th>Level 4</th>
      <th>Level 5</th>
    </tr>
  </thead>
  <tbody>
    {
      pilotsWithMaxTalents.map(({ pilot, level, talent_index, maxTalents }) => (
        <TalentPilotRow
          pilot={pilot}
          maxTalents={maxTalents}
          pilotTalents={allPilotTalents}
          fullOrOnHover={fullOrOnHover}
          highlightTalent={currentTalentId}
          highlightLevel={level}
          highlightTalentIndex={talent_index}
        />
      ))
    }
  </tbody>
</table>
