---
import langs from '../../public/langs.json';
import { URL } from 'node:url';
import '../styles/page-header.css';

// Valid language codes — passed to the inline redirect script via define:vars
const validLangs = Object.keys(langs);

export interface Props {
  title?: string;
  description?: string;
  localizedDescriptions?: { lang: string; description: string }[];
  metaImage?: string;
  url?: string;
  type?: string;
  headerImage?: string;
}

const {
  title,
  description,
  localizedDescriptions,
  metaImage,
  url,
  type = 'website',
  headerImage,
} = Astro.props;

// Generate absolute URLs
const siteUrl =
  Astro.site?.href || new URL(Astro.url.pathname, Astro.request.url).href;

// Use headerImage as default for metaImage if metaImage is not provided
const finalMetaImage = metaImage || headerImage;

// Handle image for meta tags - check if it's from data repository or public folder
let imageSrc = null;
if (finalMetaImage) {
  if (finalMetaImage.startsWith('/WRFrontiers/')) {
    // Data repository image with full path (with leading slash)
    imageSrc = `/WRFrontiersDB-Data/textures${finalMetaImage}.png`;
  } else if (finalMetaImage.startsWith('WRFrontiers/')) {
    // Data repository image with full path
    imageSrc = `/WRFrontiersDB-Data/textures/${finalMetaImage}.png`;
  } else if (finalMetaImage.startsWith('/')) {
    // Public folder image
    imageSrc = finalMetaImage;
  } else {
    // Data repository image with texture name only
    imageSrc = `/WRFrontiersDB-Data/textures${finalMetaImage}.png`;
  }
}

const imageUrl = imageSrc ? new URL(imageSrc, siteUrl).href : null;
const pageUrl = url || siteUrl;

// Handle headerImage - check if it's from data repository or public folder
let headerImageSrc = null;
if (headerImage) {
  if (headerImage.startsWith('/WRFrontiers/')) {
    // Data repository image with full path (with leading slash)
    headerImageSrc = `/WRFrontiersDB-Data/textures${headerImage}.png`;
  } else if (headerImage.startsWith('WRFrontiers/')) {
    // Data repository image with full path
    headerImageSrc = `/WRFrontiersDB-Data/textures/${headerImage}.png`;
  } else if (headerImage.startsWith('/')) {
    // Public folder image
    headerImageSrc = headerImage;
  } else {
    // Data repository image with texture name only
    headerImageSrc = `/WRFrontiersDB-Data/textures${headerImage}.png`;
  }
}

const baseUrl = import.meta.env.BASE_URL;

// Basic page layout
---

<html lang="en" id="html-root">
  <head>
    <meta charset="UTF-8" />
    <!--
      Inline script: validate `lang` query param and redirect if missing/invalid.
      Runs synchronously before page content renders to avoid a flash of wrong language.
    -->
    <script define:vars={{ validLangs }}>
      (function () {
        var params = new URLSearchParams(window.location.search);
        var lang = params.get('lang');
        if (!lang || !validLangs.includes(lang)) {
          var url = new URL(window.location.href);
          url.searchParams.set('lang', 'en');
          window.location.replace(url.toString());
        } else {
          // Set the html lang attribute now (before JS modules load)
          document.documentElement.lang = lang;
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description || 'WRFrontiersDB - War Robots Frontiers Database'}
    />
    {
      localizedDescriptions?.map(({ lang, description }) => (
        <meta name="description" lang={lang} content={description} />
      ))
    }
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="alternate icon" href={`${baseUrl}favicon.ico`} />
    {title && <title>{title}</title>}

    <!-- Open Graph Meta Tags -->
    <meta
      property="og:title"
      content={title || 'War Robots Frontiers Database'}
    />
    {description && <meta property="og:description" content={description} />}
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="War Robots Frontiers Database" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={title || 'War Robots Frontiers Database'}
    />
    {description && <meta name="twitter:description" content={description} />}
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    <slot name="head" />
  </head>
  <body>
    {
      headerImageSrc && (
        <div class="page-header-image">
          <img src={headerImageSrc} alt="Page header image" />
        </div>
      )
    }
    <select id="lang-selector">
      {
        Object.entries(langs).map(([code, names]) => (
          <option value={code}>{(names as any)[code]}</option>
        ))
      }
    </select>
    <select id="number-format-selector">
      <option value=",">1,234 (Comma)</option>
      <option value=".">1.234 (Period)</option>
    </select>
    <slot />
    <script type="module">
      const languageModule = await import('/js/language_selector.js');
      const { initLanguageSelector } = languageModule;

      // Initialize language selector (pre-selects based on lang param)
      initLanguageSelector();

      // Initialize number format selector
      const { initNumberFormatSelector } =
        await import('/js/number_format_selector.js');
      initNumberFormatSelector('number-format-selector');
    </script>

    <!--
      Href rewriter: appends or updates the `lang` query param on all internal
      anchor tags so the active language is preserved during navigation.
      Runs after DOM is ready; covers ObjRef links, Breadcrumb, nav boxes,
      BackToHome, and any inline hrefs.
    -->
    <script type="module">
      import { getCurrentLanguage } from '/js/localization.js';

      function rewriteInternalLinks() {
        const lang = getCurrentLanguage();
        document.querySelectorAll('a[href]').forEach((a) => {
          const href = a.getAttribute('href');
          // Only touch internal links (starts with / or is relative, not external)
          if (
            !href ||
            href.startsWith('http') ||
            href.startsWith('//') ||
            href.startsWith('#') ||
            href.startsWith('mailto:')
          )
            return;
          try {
            const url = new URL(href, window.location.origin);
            url.searchParams.set('lang', lang);
            a.setAttribute('href', url.pathname + url.search + url.hash);
          } catch (_) {
            // Ignore malformed hrefs
          }
        });
      }

      // Run immediately (DOM is already built for static pages)
      rewriteInternalLinks();
    </script>
  </body>
</html>
