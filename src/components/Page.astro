---
import langs from '../../public/langs.json';
import { URL } from 'node:url';
import '../styles/page-header.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
  displayImage?: string;
}

const { title, description, image, url, type = "website", displayImage } = Astro.props;

// Generate absolute URLs
const siteUrl = Astro.site?.href || new URL(Astro.url.pathname, Astro.request.url).href;

// Handle image for meta tags - check if it's from data repository or public folder
let imageSrc = null;
if (image) {
  if (image.startsWith('/WRFrontiers/')) {
    // Data repository image with full path (with leading slash)
    imageSrc = `/WRFrontiersDB-Data/textures${image}.png`;
  } else if (image.startsWith('WRFrontiers/')) {
    // Data repository image with full path
    imageSrc = `/WRFrontiersDB-Data/textures/${image}.png`;
  } else if (image.startsWith('/')) {
    // Public folder image
    imageSrc = image;
  } else {
    // Data repository image with texture name only
    imageSrc = `/WRFrontiersDB-Data/textures${image}.png`;
  }
}

const imageUrl = imageSrc ? new URL(imageSrc, siteUrl).href : null;
const pageUrl = url || siteUrl;

// Handle displayImage - check if it's from data repository or public folder
let displayImageSrc = null;
if (displayImage) {
  if (displayImage.startsWith('/WRFrontiers/')) {
    // Data repository image with full path (with leading slash)
    displayImageSrc = `/WRFrontiersDB-Data/textures${displayImage}.png`;
  } else if (displayImage.startsWith('WRFrontiers/')) {
    // Data repository image with full path
    displayImageSrc = `/WRFrontiersDB-Data/textures/${displayImage}.png`;
  } else if (displayImage.startsWith('/')) {
    // Public folder image
    displayImageSrc = displayImage;
  } else {
    // Data repository image with texture name only
    displayImageSrc = `/WRFrontiersDB-Data/textures${displayImage}.png`;
  }
}

// Basic page layout
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description || "WRFrontiersDB - War Robots Frontiers Database"}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {title && <title>{title}</title>}
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content={title || "War Robots Frontiers Database"} />
    {description && <meta property="og:description" content={description} />}
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="War Robots Frontiers Database" />
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || "War Robots Frontiers Database"} />
    {description && <meta name="twitter:description" content={description} />}
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    
    <slot name="head" />
  </head>
  <body>
    {displayImageSrc && (
      <div class="page-header-image">
        <img src={displayImageSrc} alt="Page header image" />
      </div>
    )}
    <select id="lang-selector">
      {
        Object.entries(langs).map(([code, names]) => (
          <option value={code} selected={code === 'en'}>
            {(names as any)[code]}
          </option>
        ))
      }
    </select>
    <slot />
    <script type="module">
      const languageModule = await import('/js/language_selector.js');
      const { initLanguageSelector } = languageModule;

      // Initialize language selector with default behavior (reload on change)
      initLanguageSelector();
    </script>
  </body>
</html>
