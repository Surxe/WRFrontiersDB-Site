---
import { getLatestVersionForObject } from '../../utils/summary';
import { generateObjectListStaticPaths } from '../../utils/parse_object';

export const prerender = true;

export async function getStaticPaths() {
  return generateObjectListStaticPaths('Pilot');
}

const { id } = Astro.params;

// Get the latest version for this pilot
const latestVersion = getLatestVersionForObject(id as string, 'Pilot');

if (!latestVersion) {
  return Astro.redirect('/pilots');
}

// Redirect to the latest version
return Astro.redirect(`/pilots/${id}/${latestVersion}`);
---
