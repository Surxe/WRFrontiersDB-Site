---
import Breadcrumb from '../components/Breadcrumb.astro';
import ParseObjectListPage from '../components/ParseObjectListPage.astro';
import { getCharacterPresetsBreadcrumbs } from '../utils/breadcrumb';
import { getParseObjects } from '../utils/parse_object';
import { prepareObjectList } from '../utils/list';
import ModuleRef from '../components/obj_ref/ModuleRef.astro';
import { refToId } from '../utils/object_reference';

// Load character presets, modules, and module types
const presets = getParseObjects('Objects/CharacterPreset.json');
const modules = getParseObjects('Objects/Module.json');

// Prepare and filter presets
const entries = prepareObjectList(presets, { prodReadyOnly: false });

// Sort presets by name
const sortedPresets = entries.sort(([_a, a], [_b, b]) => {
  const nameA = (a.name as any)?.en || a.id;
  const nameB = (b.name as any)?.en || b.id;
  return nameA.localeCompare(nameB);
});
---

<ParseObjectListPage
  title="Character Presets"
  description="Browse all character presets from War Robots Frontiers"
  headerImage="/images/T_UnLockPilots.png"
>
  <Breadcrumb breadcrumbs={getCharacterPresetsBreadcrumbs()} />

  <h1>Character Presets</h1>

  <div class="presets-list">
    {sortedPresets.map(([_id, preset]) => (
      <div class="preset-item">
        <ModuleRef obj={preset} showIcon={false} />
        <p>
          {preset.is_factory_preset ? 'Factory' : 'Custom'} • {preset.character_type}
        </p>
        <p>Pilot: {preset.pilot_ref}</p>
        {preset.is_factory_preset ? (
          <p>Modules: {Object.keys(preset.modules as any).length}</p>
        ) : (
          <div class="modules-list">
            <strong>Modules:</strong>
            {Object.values(preset.modules as any).map((moduleInfo: any) => {
              const moduleId = refToId(moduleInfo.module_ref as string);
              const module = modules[moduleId];
              if (!module) {
                return <span>{moduleInfo.module_ref}</span>;
              }
              
              return <span style="margin-right: 0.5rem;"><ModuleRef obj={module} showIcon={false} /></span>;
            })}
          </div>
        )}
      </div>
    ))}
  </div>
</ParseObjectListPage>

<style>
  .presets-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .preset-item {
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #f9f9f9;
  }

  
  .preset-item p {
    margin: 0.25rem 0;
    color: #666;
  }

  .modules-list {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .modules-list strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #333;
  }

  </style>
