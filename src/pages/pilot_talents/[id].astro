---
import { getLatestVersionForObject } from '../../utils/summary';
import { generateObjectListStaticPaths } from '../../utils/parse_object';

export const prerender = true;

export async function getStaticPaths() {
  return generateObjectListStaticPaths('PilotTalent');
}

const { id } = Astro.params;

// Get the latest version for this pilot talent
const latestVersion = getLatestVersionForObject(id as string, 'PilotTalent');

if (!latestVersion) {
  return Astro.redirect('/pilot_talents');
}

// Redirect to the latest version
return Astro.redirect(`/pilot_talents/${id}/${latestVersion}`);
---
