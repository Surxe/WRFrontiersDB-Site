---
import type { ModuleCategory, Module } from '../../types/module';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import {
  getParseObject,
  generateObjectListStaticPaths,
  getParseObjects,
} from '../../utils/parse_object';
import { getDefaultString } from '../../utils/localization';
import { getModuleCategoryDetailBreadcrumbs } from '../../utils/breadcrumb';
import ObjRef from '../../components/obj_ref/ObjRef.astro';

export async function getStaticPaths() {
  // Load slug map to generate slug-based paths
  const fs = await import('fs/promises');
  const path = await import('path');
  const projectRoot = process.cwd();
  const slugMapPath = path.join(projectRoot, 'public', 'slug-map.json');
  
  let slugMap = {};
  try {
    const content = await fs.readFile(slugMapPath, 'utf-8');
    slugMap = JSON.parse(content);
  } catch (error) {
    console.warn('Could not load slug map, falling back to ID-based paths');
    return generateObjectListStaticPaths('ModuleCategory');
  }

  // Get all module categories
  const categories = getParseObjects<ModuleCategory>('Objects/ModuleCategory.json');
  const paths = [];

  for (const [categoryId, category] of Object.entries(categories)) {
    // Skip categories without production_status = 'Ready' for production
    if (import.meta.env.PROD && category.production_status !== 'Ready') {
      continue;
    }

    const slug = slugMap[categoryId];
    if (slug) {
      paths.push({
        params: { slug },
        props: { id: categoryId }
      });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const { id } = Astro.props;

const moduleCategory = getParseObject<ModuleCategory>(
  id,
  'Objects/ModuleCategory.json'
);

if (!moduleCategory.name) {
  throw new Error(`ModuleCategory with id ${id} is missing name.`);
}

// Extract English text as fallback
const defaultName = getDefaultString(moduleCategory.name) || moduleCategory.id;

// Get modules for this category
const modules = getParseObjects<Module>('Objects/Module.json');
const categoryModules = Object.values(modules).filter(
  (module) => module.module_category_ref === `OBJID_ModuleCategory::${id}`
);
---

<ParseObjectPage
  title={defaultName}
  description={`View details for module category ${defaultName} from War Robots Frontiers`}
  headerImage={moduleCategory.image_path}
  type="article"
>
  <LocalizedText
    id="module-category-name-title"
    tag="title"
    localizationKey={moduleCategory.name}
    slot="head"
  />
  <Breadcrumb breadcrumbs={getModuleCategoryDetailBreadcrumbs(moduleCategory)} />
  <LocalizedText id="module-category-name" tag="h1" localizationKey={moduleCategory.name} />

  <Icon iconPath={moduleCategory.inventory_icon_path} altText={`${defaultName} icon`} />

  {
    moduleCategory.description && (
      <div class="module-category-description-section">
        <LocalizedText id="module-category-desc" tag="p" localizationKey={moduleCategory.description} />
      </div>
    )
  }

  <h3>Modules in this Category</h3>
  <div class="module-category-modules">
    {categoryModules.map((module) => (
      <div class="module-item">
        <ObjRef obj={module} />
      </div>
    ))}
  </div>

  <p>Language: <span id="current-lang">en</span></p>

  <ObjectPageScripts objectData={moduleCategory} />
</ParseObjectPage>
