---
import { getLatestVersionForObject } from '../../utils/summary';
import { generateObjectListStaticPaths } from '../../utils/parse_object';

export const prerender = true;

export async function getStaticPaths() {
  return generateObjectListStaticPaths('PilotPersonality');
}

const { id } = Astro.params;

// Get the latest version for this pilot personality
const latestVersion = getLatestVersionForObject(
  id as string,
  'PilotPersonality'
);

if (!latestVersion) {
  return Astro.redirect('/pilot_personalities');
}

// Redirect to the latest version
return Astro.redirect(`/pilot_personalities/${id}/${latestVersion}`);
---
