---
import type { PilotPersonality } from '../../types/pilot';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import {
  getParseObject,
  getParseObjects,
  generateObjectListStaticPaths,
} from '../../utils/parse_object';
import { getDefaultString } from '../../utils/localization';
import { getPilotPersonalityDetailBreadcrumbs } from '../../utils/breadcrumb';
import { generateSimpleLocalizedMetaDescriptions } from '../../utils/build_localization';
import PilotPersonalitiesNavBox from '../../components/nav/PilotPersonalitiesNavBox.astro';

export async function getStaticPaths() {
  // Load slug map to generate slug-based paths
  const fs = await import('fs/promises');
  const path = await import('path');
  const projectRoot = process.cwd();
  const slugMapPath = path.join(projectRoot, 'public', 'slug-map.json');
  
  let slugMap = {};
  try {
    const content = await fs.readFile(slugMapPath, 'utf-8');
    slugMap = JSON.parse(content);
  } catch (error) {
    console.warn('Could not load slug map, falling back to ID-based paths');
    return generateObjectListStaticPaths('PilotPersonality');
  }

  // Get all pilot personalities
  const personalities = getParseObjects<PilotPersonality>('Objects/PilotPersonality.json');
  const paths = [];

  for (const [personalityId, personality] of Object.entries(personalities)) {
    // Skip personalities without production_status = 'Ready' for production
    if (import.meta.env.PROD && personality.production_status !== 'Ready') {
      continue;
    }

    const slug = slugMap[personalityId];
    if (slug) {
      paths.push({
        params: { slug },
        props: { id: personalityId }
      });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const { id } = Astro.props;

const pilotPersonality = getParseObject<PilotPersonality>(
  id,
  'Objects/PilotPersonality.json'
);

// Extract English text as fallback
const defaultName =
  getDefaultString(pilotPersonality.name) || pilotPersonality.id;

// Generate localized meta descriptions
const localizedDescriptions = generateSimpleLocalizedMetaDescriptions(
  { Key: 'PilotPersonality_Meta_Description', TableNamespace: 'Web_UI' },
  { name: pilotPersonality.name },
  defaultName
);
---

<ParseObjectPage
  localizedDescriptions={localizedDescriptions}
  headerImage={pilotPersonality.image_path}
  type="article"
>
  <LocalizedText
    id="pilot-personality-name-title"
    tag="title"
    localizationKey={pilotPersonality.name}
    slot="head"
  />
  <Breadcrumb breadcrumbs={getPilotPersonalityDetailBreadcrumbs(pilotPersonality)} />
  <LocalizedText id="pilot-personality-name" tag="h1" localizationKey={pilotPersonality.name} />

  <Icon iconPath={pilotPersonality.inventory_icon_path} altText={`${defaultName} icon`} />

  <p>Language: <span id="current-lang">en</span></p>

  <PilotPersonalitiesNavBox currentPersonality={pilotPersonality} />

  <ObjectPageScripts objectData={pilotPersonality} />
</ParseObjectPage>
