---
import Breadcrumb from '../../components/Breadcrumb.astro';
import ParseObjectListPage from '../../components/ParseObjectListPage.astro';
import BotItem from '../../components/bot/BotItem.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import {
  getParseObject,
  getParseObjects,
  generateSlugBasedStaticPaths,
} from '../../utils/parse_object';
import { getCharacterPresetDetailBreadcrumbs } from '../../utils/breadcrumb';
import { getDefaultString } from '../../utils/localization';
import { getObjRefData } from '../../utils/obj_ref';
import TextElements from '../../components/obj_ref/TextElements.astro';
import type { CharacterPreset } from '../../types/character_preset';

export async function getStaticPaths() {
  return generateSlugBasedStaticPaths('CharacterPreset');
}

const { slug: _slug } = Astro.params;
const { id } = Astro.props;

const preset = getParseObject(
  id,
  'Objects/CharacterPreset.json'
) as CharacterPreset;
const pilots = getParseObjects('Objects/Pilot.json');
const modules = getParseObjects('Objects/Module.json');

const objRefData = preset ? getObjRefData(preset) : null;
---

<ParseObjectListPage
  title={objRefData ? [objRefData.text as any, { InvariantString: '- Factory Preset' }] : 'Character Preset'}
  description={`View details for character preset ${getDefaultString(preset?.name) || preset?.id} from War Robots Frontiers`}
  headerImage="/images/T_UnLockPilots.png"
>
  <Breadcrumb breadcrumbs={getCharacterPresetDetailBreadcrumbs(preset)} />

  {
    preset ? (
      <div class="character-preset-detail">
        <h1>
          <TextElements
            textElements={Array.isArray(objRefData!.text)
              ? (objRefData!.text as any)
              : [objRefData!.text as any]}
          />
        </h1>

        <BotItem preset={preset} modules={modules} pilots={pilots} />
      </div>
    ) : (
      <div class="character-preset-not-found">
        <h1>Character Preset Not Found</h1>
        <p>The character preset with ID {id} was not found.</p>
      </div>
    )
  }

  <ObjectPageScripts objectData={preset} />
</ParseObjectListPage>
