---
import Breadcrumb from '../../components/Breadcrumb.astro';
import ParseObjectListPage from '../../components/ParseObjectListPage.astro';
import BotItem from '../../components/bot/BotItem.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import {
  getParseObject,
  getParseObjects,
  generateObjectListStaticPaths,
} from '../../utils/parse_object';
import { getCharacterPresetDetailBreadcrumbs } from '../../utils/breadcrumb';
import { getDefaultString } from '../../utils/localization';
import type { CharacterPreset } from '../../types/character_preset';

export async function getStaticPaths() {
  // Load slug map to generate slug-based paths
  const fs = await import('fs/promises');
  const path = await import('path');
  const projectRoot = process.cwd();
  const slugMapPath = path.join(projectRoot, 'public', 'slug-map.json');
  
  let slugMap = {};
  try {
    const content = await fs.readFile(slugMapPath, 'utf-8');
    slugMap = JSON.parse(content);
  } catch (error) {
    console.warn('Could not load slug map, falling back to ID-based paths');
    return generateObjectListStaticPaths('CharacterPreset');
  }

  // Get all character presets
  const presets = getParseObjects<CharacterPreset>('Objects/CharacterPreset.json');
  const paths = [];

  for (const [presetId, preset] of Object.entries(presets)) {
    // Skip presets without production_status = 'Ready' for production
    if (import.meta.env.PROD && preset.production_status !== 'Ready') {
      continue;
    }

    const slug = slugMap[presetId];
    if (slug) {
      paths.push({
        params: { slug },
        props: { id: presetId }
      });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const { id } = Astro.props;

const preset = getParseObject(
  id,
  'Objects/CharacterPreset.json'
) as CharacterPreset;
const pilots = getParseObjects('Objects/Pilot.json');
const modules = getParseObjects('Objects/Module.json');
---

<ParseObjectListPage
  title={getDefaultString(preset?.name) || preset?.id || 'Character Preset'}
  description={`View details for character preset ${getDefaultString(preset?.name) || preset?.id} from War Robots Frontiers`}
  headerImage="/images/T_UnLockPilots.png"
>
  <Breadcrumb breadcrumbs={getCharacterPresetDetailBreadcrumbs(preset)} />

  {
    preset ? (
      <div class="character-preset-detail">
        <h1>{getDefaultString(preset.name) || preset.id}</h1>

        <BotItem
          preset={preset}
          allModules={modules}
          allPilots={pilots}
        />
      </div>
    ) : (
      <div class="character-preset-not-found">
        <h1>Character Preset Not Found</h1>
        <p>The character preset with ID {id} was not found.</p>
      </div>
    )
  }

  <ObjectPageScripts objectData={preset} />
</ParseObjectListPage>
