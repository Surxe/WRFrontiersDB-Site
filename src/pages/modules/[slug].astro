---
import type {
  Module,
  ModuleRarity,
  ModuleStatsTable,
} from '../../types/module';
import type { CharacterModule } from '../../types/character_module';
import type { Ability } from '../../types/ability';
import type { Rarity } from '../../types/rarity';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import {
  getParseObject,
  getParseObjects,
  generateSlugBasedStaticPaths,
} from '../../utils/parse_object';
import { getDefaultString } from '../../utils/localization';
import { generateSimpleLocalizedMetaDescriptions } from '../../utils/build_localization';
import { resolveObjectRef } from '../../utils/object_resolver';
import type { ModuleStat } from '../../types/module';
import {
  getModuleStatValueChoices,
  getModuleAbilityStats,
} from '../../utils/stat';
import StatEmbedLocalizedText from '../../components/StatEmbedLocalizedText.astro';
import LevelSwitcher from '../../components/LevelSwitcher.astro';
import ObjRef from '../../components/obj_ref/ObjRef.astro';
import ModulesNavBox from '../../components/nav/ModulesNavBox.astro';
import { isCoreModule } from '../../utils/core_modules';
import { getModuleDetailBreadcrumbs } from '../../utils/breadcrumb';
import BotsList from '../../components/bot/BotsList.astro';
import BotCoreModulesNavBox from '../../components/nav/BotCoreModulesNavBox.astro';
import { refToId } from '../../utils/object_reference';
import { getObjRefData } from '../../utils/obj_ref';
import TextElements from '../../components/obj_ref/TextElements.astro';
import type { CharacterPreset } from '../../types/character_preset';
import type { Pilot } from '../../types/pilot';

export async function getStaticPaths() {
  return generateSlugBasedStaticPaths('Module');
}

const { slug: _slug } = Astro.params;
const { id } = Astro.props;

const module = getParseObject<Module>(id, 'Objects/Module.json');
const allModuleRarities = getParseObjects<ModuleRarity>(
  'Objects/ModuleRarity.json'
);
const moduleRarity = resolveObjectRef(
  module.module_rarity_ref,
  allModuleRarities
);
const allRarities = getParseObjects<Rarity>('Objects/Rarity.json');
const rarity = moduleRarity
  ? resolveObjectRef(moduleRarity.rarity_ref, allRarities)
  : undefined;

// Get module group for this module
const moduleGroupId = module.module_group_ref
  ? refToId(module.module_group_ref)
  : undefined;

// Get stat choices for leveled descriptions
const allModuleStats = getParseObjects<ModuleStat>('Objects/ModuleStat.json');
const allModuleStatsTables = getParseObjects<ModuleStatsTable>(
  'Objects/ModuleStatsTable.json'
);

const statValueChoices = getModuleStatValueChoices(
  module,
  allModuleStats,
  allModuleStatsTables,
  getDefaultString(module.description)
);

// Get ability-linked descriptions
const allCharacterModules = getParseObjects<CharacterModule>(
  'Objects/CharacterModule.json'
);
const allAbilities = getParseObjects<Ability>('Objects/Ability.json');
const abilityStats = getModuleAbilityStats(
  module,
  allCharacterModules,
  allAbilities,
  allModuleStats,
  allModuleStatsTables
);

const maxLevel = module.module_scalars?.levels?.variables?.length || 0;

if (!module.name) {
  throw new Error(`Module with id ${id} is missing name. 
  This is expected only for non production ready modules.`);
}

// Extract English text as fallback
const defaultName = getDefaultString(module.name) || module.id;

// Generate localized meta descriptions
const localizedDescriptions = generateSimpleLocalizedMetaDescriptions(
  { Key: 'Module_Meta_Description', TableNamespace: 'Web_UI' },
  { name: module.name! },
  defaultName
);

// Core Module Factory Bots logic
const isCore = isCoreModule(module);
let factoryBots: [string, CharacterPreset][] = [];
let allModulesForBots = {};
let allPilotsForBots = {};

if (isCore) {
  const allPresets = getParseObjects<CharacterPreset>(
    'Objects/CharacterPreset.json'
  );
  allModulesForBots = getParseObjects<Module>('Objects/Module.json');
  allPilotsForBots = getParseObjects<Pilot>('Objects/Pilot.json');

  factoryBots = Object.entries(allPresets).filter(([_, preset]) => {
    if (!preset.is_factory_preset) return false;
    return Object.values(preset.modules).some(
      (m) => refToId(m.module_ref) === module.id
    );
  }) as [string, CharacterPreset][];

  // Sort by name
  factoryBots.sort(([_a, a], [_b, b]) => {
    const nameA = getDefaultString(a.name as any) || a.id;
    const nameB = getDefaultString(b.name as any) || b.id;
    return nameA.localeCompare(nameB);
  });
}

let botCoreModulesNavBox: string | null = null;

if (isCore && module.virtual_bot_ref) {
  botCoreModulesNavBox = refToId(module.virtual_bot_ref);
}

const objRefData = getObjRefData(module);
---

<ParseObjectPage
  title={objRefData.text}
  localizedDescriptions={localizedDescriptions}
  headerImage={module.image_path as string}
  type="article"
>
  <Breadcrumb breadcrumbs={getModuleDetailBreadcrumbs(module)} />
  <h1 id="module-name">
    <TextElements
      textElements={Array.isArray(objRefData.text)
        ? objRefData.text
        : [objRefData.text]}
    />
  </h1>

  <Icon iconPath={module.inventory_icon_path} altText={`${defaultName} icon`} />

  <!-- Direct description block - shown if no abilities or abilities without scalars -->
  {
    module.description &&
      !(abilityStats.length > 0 && module.abilities_scalars) && (
        <div class="module-description-section">
          <StatEmbedLocalizedText
            id="module-desc"
            tag="p"
            localizationKey={module.description}
            statValueChoices={statValueChoices}
          />

          {maxLevel > 0 && <LevelSwitcher maxLevel={maxLevel} />}
        </div>
      )
  }

  <!-- Abilities block - shown if abilities with scalars -->
  {
    abilityStats.length > 0 && module.abilities_scalars && (
      <div class="module-abilities-section">
        {abilityStats.map((abStat, index) => (
          <div class="ability-block" style="margin-top: 1.5rem;">
            {abStat.ability.name && (
              <LocalizedText
                id={`ability-name-${index}`}
                tag="h3"
                localizationKey={abStat.ability.name}
              />
            )}
            {abStat.ability.description && (
              <StatEmbedLocalizedText
                id={`ability-desc-${index}`}
                tag="p"
                localizationKey={abStat.ability.description}
                statValueChoices={abStat.statValueChoices}
              />
            )}
          </div>
        ))}

        {maxLevel > 0 && (abilityStats.length > 1 || !module.description) && (
          <LevelSwitcher maxLevel={maxLevel} />
        )}
      </div>
    )
  }
  <p>Language: <span id="current-lang">en</span></p>
  <p>
    Rarity:
    {rarity ? <ObjRef obj={rarity} useHref={false} /> : 'Unknown'}
  </p>

  <div id="stats">stats</div>

  {
    moduleGroupId && (
      <section style="margin-top: 2rem;">
        <h2>Related Modules</h2>
        <ModulesNavBox moduleGroupId={moduleGroupId} />
      </section>
    )
  }

  {
    botCoreModulesNavBox && (
      <section style="margin-top: 2rem;">
        <BotCoreModulesNavBox
          botId={botCoreModulesNavBox}
        />
      </section>
    )
  }

  {
    isCore && factoryBots.length > 0 && (
      <section id="factory-bots-section" style="margin-top: 2rem;">
        <h2>Factory Bots using this Module</h2>
        <BotsList
          presets={factoryBots}
          modules={allModulesForBots}
          pilots={allPilotsForBots}
        />
      </section>
    )
  }

  <ObjectPageScripts objectData={module} jsFileName="module_page.js" slug={_slug} />
</ParseObjectPage>
