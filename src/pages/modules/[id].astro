---
import { getLatestVersionForObject } from '../../utils/summary';
import { generateObjectListStaticPaths } from '../../utils/parse_object';

export const prerender = true;

export async function getStaticPaths() {
  return generateObjectListStaticPaths('Module');
}

const { id } = Astro.params;

// Get the latest version for this module
const latestVersion = getLatestVersionForObject(id as string, 'Module');

if (!latestVersion) {
  return Astro.redirect('/modules');
}

// Redirect to the latest version
return Astro.redirect(`/modules/${id}/${latestVersion}`);
---
