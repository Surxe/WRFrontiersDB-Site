---
import Breadcrumb from '../../components/Breadcrumb.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ModuleGroupsNavBox from '../../components/nav/ModuleGroupsNavBox.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import {
  MODULE_GROUPS,
  getAllModuleGroupIds,
  getModuleGroupDescription,
  enrichModulesWithGroups,
} from '../../utils/module_group_mapping';
import { getParseObjects } from '../../utils/parse_object';
import { generateSimpleLocalizedMetaDescriptions } from '../../utils/build_localization';
import { getModuleGroupDetailBreadcrumbs } from '../../utils/breadcrumb';
import { prepareObjectList } from '../../utils/list';
import type { ModuleType, Module, ModuleCategory } from '../../types/module';
import ObjRef from '../../components/obj_ref/ObjRef.astro';
import { getDefaultString } from '../../utils/localization';

export async function getStaticPaths() {
  // Load slug map to get module group slugs
  const fs = await import('fs/promises');
  const path = await import('path');
  const projectRoot = process.cwd();
  const slugMapPath = path.join(projectRoot, 'public', 'slug-map.json');
  
  try {
    const content = await fs.readFile(slugMapPath, 'utf-8');
    const slugMap = JSON.parse(content);
    
    // Get all module group IDs and their slugs
    const groupIds = getAllModuleGroupIds();
    return groupIds.map((id) => {
      const slug = slugMap[id];
      if (!slug) {
        throw new Error(`No slug found for module group: ${id}`);
      }
      return {
        params: { slug },
        props: { id }
      };
    });
  } catch (error) {
    console.error('Could not load slug map for module groups:', error);
    throw new Error('Failed to generate module group slug paths');
  }
}

const { slug } = Astro.params;
const { id } = Astro.props;

const group = MODULE_GROUPS[id as keyof typeof MODULE_GROUPS];

if (!group) {
  throw new Error(`Module group not found: ${id}`);
}

// Load module types to get dynamic descriptions
const moduleTypes = getParseObjects<ModuleType>('Objects/ModuleType.json');

// Load modules, module types, and module categories
const modules = getParseObjects<Module>('Objects/Module.json');
const moduleCategories = getParseObjects<ModuleCategory>(
  'Objects/ModuleCategory.json'
);

// Enrich modules with their module group assignments
const enrichedModules = enrichModulesWithGroups(
  modules,
  moduleTypes,
  moduleCategories
);

// Filter modules for this specific group and production-ready only
const allGroupModules = Object.entries(enrichedModules).filter(
  ([_, module]) => module.module_group === id
);

// Use prepareObjectList to filter production-ready modules
const filteredModules = prepareObjectList(Object.fromEntries(allGroupModules), {
  prodReadyOnly: true,
}).sort(([_a, a], [_b, b]) => {
  // Sort by module name
  const nameA = a.name?.Key || a.id;
  const nameB = b.name?.Key || b.id;
  return nameA.localeCompare(nameB);
});

// Get the dynamic description for this module group
let dynamicDescription:
  | { Key: string; TableNamespace: string; en: string }
  | undefined;
try {
  dynamicDescription = getModuleGroupDescription(
    id as keyof typeof MODULE_GROUPS,
    moduleTypes
  );
} catch {
  // No description available for this module group - dynamicDescription remains undefined
}

// Generate localized meta descriptions
const localizedDescriptions = generateSimpleLocalizedMetaDescriptions(
  { Key: 'ModuleGroup_Meta_Description', TableNamespace: 'Web_UI' },
  {
    groupName: group.name,
    groupDescription: dynamicDescription || {
      Key: '',
      TableNamespace: '',
      en: '',
    },
  },
  getDefaultString(group.name) || id
);
---

<ParseObjectPage
  title={`${getDefaultString(group.name)} - Module Group`}
  localizedDescriptions={localizedDescriptions}
  type="article"
>
  <Breadcrumb breadcrumbs={getModuleGroupDetailBreadcrumbs(id)} />

  <LocalizedText id="category-name" tag="h1" localizationKey={group.name} />

  {
    dynamicDescription && (
      <LocalizedText
        id="category-desc"
        tag="p"
        localizationKey={dynamicDescription}
        stripColorMarkup={true}
      />
    )
  }
  <p>Language: <span id="current-lang">en</span></p>

  {
    filteredModules.length > 0 && (
      <section>
        <h2>Modules in this group</h2>
        <ul>
          {filteredModules.map(([_id, module]) => (
            <li>
              <ObjRef obj={module} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <ModuleGroupsNavBox />

  <ObjectPageScripts objectData={{}} />
</ParseObjectPage>
