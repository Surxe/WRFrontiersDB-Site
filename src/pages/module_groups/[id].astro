---
import Breadcrumb from '../../components/Breadcrumb.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ModulesNavBox from '../../components/nav/ModulesNavBox.astro';
import {
  MODULE_GROUPS,
  getAllModuleGroupIds,
  getModuleGroupDescription,
} from '../../utils/module_group_mapping';
import { getParseObjects } from '../../utils/parse_object';
import { generateSimpleLocalizedMetaDescriptions } from '../../utils/build_localization';
import { getModuleGroupDetailBreadcrumbs } from '../../utils/breadcrumb';
import type { ModuleType } from '../../types/module';

export async function getStaticPaths() {
  const groupIds = getAllModuleGroupIds();
  return groupIds.map((id) => ({
    params: { id },
  }));
}

const { id } = Astro.params;

const group = MODULE_GROUPS[id as keyof typeof MODULE_GROUPS];

if (!group) {
  throw new Error(`Module group not found: ${id}`);
}

// Load module types to get dynamic descriptions
const moduleTypes = getParseObjects<ModuleType>('Objects/ModuleType.json');

// Get the dynamic description for this module group
let dynamicDescription: { Key: string; TableNamespace: string; en: string } | undefined;
try {
  dynamicDescription = getModuleGroupDescription(id as keyof typeof MODULE_GROUPS, moduleTypes);
} catch {
  // No description available for this module group - dynamicDescription remains undefined
}

// Generate localized meta descriptions
const localizedDescriptions = generateSimpleLocalizedMetaDescriptions(
  { Key: 'ModuleGroup_Meta_Description', TableNamespace: 'Web_UI' },
  {
    groupName: group.name,
    groupDescription: dynamicDescription || { Key: '', TableNamespace: '', en: '' },
  },
  group.name.en || id
);
---

<ParseObjectPage
  title={`${group.name.en} - Module Group`}
  localizedDescriptions={localizedDescriptions}
  type="article"
>
  <Breadcrumb breadcrumbs={getModuleGroupDetailBreadcrumbs(id)} />

  <LocalizedText id="category-name" tag="h1" localizationKey={group.name} />

  {
    dynamicDescription && (
      <LocalizedText
        id="category-desc"
        tag="p"
        localizationKey={dynamicDescription}
      />
    )
  }
  <p>Language: <span id="current-lang">en</span></p>
  
  <ModulesNavBox moduleGroupId={id} />
</ParseObjectPage>
