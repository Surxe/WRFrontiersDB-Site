---
// Redirect to the default pilots view
import { URL } from 'node:url';

// Get the current URL and preserve query parameters
const currentUrl = Astro.url;
const redirectUrl = new URL('/pilots/talent-overview', currentUrl.origin);
// Preserve all query parameters from the current URL
currentUrl.searchParams.forEach((value, key) => {
  redirectUrl.searchParams.set(key, value);
});

const finalRedirectUrl = redirectUrl.pathname + redirectUrl.search;
const canonicalUrl = redirectUrl.pathname + redirectUrl.search;
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to Pilots...</title>
    <meta http-equiv="refresh" content={`0; url=${finalRedirectUrl}`} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <p>
      Redirecting to <a href={finalRedirectUrl}>Talent Overview</a>...
    </p>
  </body>
</html>
