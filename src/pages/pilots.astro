---
// Redirect to the default pilots view
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to Pilots...</title>
    <script>
      // Client-side redirect that preserves query parameters
      (function () {
        const currentUrl = new URL(window.location.href);
        const redirectUrl = new URL(
          '/pilots/talent-overview',
          window.location.origin
        );

        // Preserve all query parameters from the current URL
        currentUrl.searchParams.forEach((value, key) => {
          redirectUrl.searchParams.set(key, value);
        });

        // Perform the redirect
        window.location.replace(redirectUrl.toString());
      })();
    </script>
  </head>
  <body>
    <p>
      Redirecting to <a href="/pilots/talent-overview">Talent Overview</a>...
    </p>
  </body>
</html>
