---
import type { PilotTalentType, PilotTalent } from '../../types/pilot';
import type { ModuleStat } from '../../types/module';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import ObjRef from '../../components/obj_ref/ObjRef.astro';
import {
  getParseObject,
  getParseObjects,
  generateSlugBasedStaticPaths,
} from '../../utils/parse_object';
import { getStatValueChoices } from '../../utils/stat';
import { generatePilotTalentTypeLocalizedMetaDescriptions } from '../../utils/build_localization';
import PilotTalentTypesNavBox from '../../components/nav/PilotTalentTypesNavBox.astro';
import { getPilotTalentTypeDetailBreadcrumbs } from '../../utils/breadcrumb';

export async function getStaticPaths() {
  return generateSlugBasedStaticPaths('PilotTalentType');
}

const { slug: _slug } = Astro.params;
const { id } = Astro.props;

const pilotTalentType = getParseObject<PilotTalentType>(
  id,
  'Objects/PilotTalentType.json'
);

// Load ModuleStats for stat replacements
const moduleStats = getParseObjects<ModuleStat>('Objects/ModuleStat.json');

// Load pilot talents - now enriched by parser
const pilotTalents = getParseObjects<PilotTalent>('Objects/PilotTalent.json');

// Get talents for this talent type
const talentsForThisType = Object.values(pilotTalents).filter(
  (talent) => talent.talent_type_ref === `OBJID_PilotTalentType::${id}`
);

// Generate localized meta descriptions
const localizedDescriptions = generatePilotTalentTypeLocalizedMetaDescriptions(
  pilotTalentType,
  talentsForThisType.map((talent) => [talent.id, talent] as [string, PilotTalent]),
  id
);
---

<ParseObjectPage
  localizedDescriptions={localizedDescriptions}
  headerImage={pilotTalentType.image_path}
  type="article"
>
  <LocalizedText
    id="pilot-talent-type-name-title"
    tag="title"
    localizationKey={pilotTalentType.name}
    slot="head"
  />
  <Breadcrumb
    breadcrumbs={getPilotTalentTypeDetailBreadcrumbs(pilotTalentType)}
  />
  <LocalizedText
    id="pilot-talent-type-name"
    tag="h1"
    localizationKey={pilotTalentType.name}
  />

  <Icon
    iconPath={pilotTalentType.inventory_icon_path}
    altText={`${pilotTalentType.id} icon`}
  />

  {
    pilotTalentType.description && (
      <div class="pilot-talent-type-description-section">
        <LocalizedText
          id="pilot-talent-type-desc"
          tag="p"
          localizationKey={pilotTalentType.description}
        />
      </div>
    )
  }

  <h3>Talents</h3>
  <div class="pilot-talent-type-talents">
    {
      talentsForThisType.map((talent) => (
        <div class="talent-item">
          <ObjRef
            obj={talent}
            useOnHover={true}
            onHoverStatChoices={getStatValueChoices(talent.stats, moduleStats)}
          />
        </div>
      ))
    }
  </div>

  <p>Language: <span id="current-lang">en</span></p>

  <PilotTalentTypesNavBox currentTalentType={pilotTalentType} />

  <ObjectPageScripts objectData={pilotTalentType} />
</ParseObjectPage>
