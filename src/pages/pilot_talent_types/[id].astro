---
import { getLatestVersionForObject } from '../../utils/summary';
import { generateObjectListStaticPaths } from '../../utils/parse_object';

export const prerender = true;

export async function getStaticPaths() {
  return generateObjectListStaticPaths('PilotTalentType');
}

const { id } = Astro.params;

// Get the latest version for this pilot talent type
const latestVersion = getLatestVersionForObject(
  id as string,
  'PilotTalentType'
);

if (!latestVersion) {
  return Astro.redirect('/pilot_talent_types');
}

// Redirect to the latest version
return Astro.redirect(`/pilot_talent_types/${id}/${latestVersion}`);
---
