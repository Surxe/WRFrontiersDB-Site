---
import type { ModuleCategory } from '../../types/module';
import Breadcrumb from '../components/Breadcrumb.astro';
import ParseObjectListPage from '../components/ParseObjectListPage.astro';
import { getParseObjects } from '../utils/parse_object';
import { prepareObjectList, groupBy, sortGroups } from '../utils/list';
import { getModuleGroupsBreadcrumbs } from '../utils/breadcrumb';
import { getDefaultString } from '../utils/localization';
import ObjRef from '../components/obj_ref/ObjRef.astro';

const moduleCategories = getParseObjects<ModuleCategory>(
  'Objects/ModuleCategory.json'
);

// Prepare categories (no production filtering since ModuleCategory doesn't have production_status)
const entries = prepareObjectList(moduleCategories, { prodReadyOnly: false });

// Group by name for sorting
const grouped = groupBy(
  entries,
  ([_category, category]) => getDefaultString(category.name) || 'Unknown'
);

// Sort groups alphabetically
const sortedGroups = sortGroups(grouped);
---

<ParseObjectListPage
  title="Module Categories"
  description="Browse all module categories with their descriptions and icons"
  headerImage="/images/T_AlphaUnlock.png"
>
  <Breadcrumb breadcrumbs={getModuleGroupsBreadcrumbs()} />
  <h1>Module Categories</h1>

  {
    sortedGroups.map(([categoryName, categoryEntries]) => (
      <section>
        <h2>{categoryName}</h2>
        <ul>
          {categoryEntries.map(([_id, category]) => (
            <li>
              <ObjRef obj={category} />
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</ParseObjectListPage>
