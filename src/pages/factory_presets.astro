---
import Breadcrumb from '../components/Breadcrumb.astro';
import ParseObjectListPage from '../components/ParseObjectListPage.astro';
import { getFactoryPresetsBreadcrumbs } from '../utils/breadcrumb';
import { getParseObjects } from '../utils/parse_object';
import { prepareObjectList } from '../utils/list';
import ObjRef from '../components/obj_ref/ObjRef.astro';
import { refToId } from '../utils/object_reference';

// Load character presets and modules
const presets = getParseObjects('Objects/CharacterPreset.json');
const modules = getParseObjects('Objects/Module.json');

// Prepare and filter to only factory presets
const entries = prepareObjectList(presets, { prodReadyOnly: false });
const factoryEntries = entries.filter(([_, preset]) => preset.is_factory_preset);

// Sort presets by name
const sortedPresets = factoryEntries.sort(([_a, a], [_b, b]) => {
  const nameA = a.name?.en || a.id;
  const nameB = b.name?.en || b.id;
  return nameA.localeCompare(nameB);
});
---

<ParseObjectListPage
  title="Factory Presets"
  description="Browse all factory character presets from War Robots Frontiers"
  headerImage="/images/T_UnLockPilots.png"
>
  <Breadcrumb breadcrumbs={getFactoryPresetsBreadcrumbs()} />

  <h1>Factory Presets</h1>

  <div class="presets-list">
    {sortedPresets.map(([id, preset]) => (
      <div class="preset-item">
        <ObjRef obj={preset} showIcon={false} />
        <p>
          Factory • {preset.character_type}
        </p>
        <p>Pilot: {preset.pilot_ref}</p>
        <div class="modules-list">
          <strong>Modules:</strong>
          {Object.values(preset.modules).map((moduleInfo) => {
            const moduleId = refToId(moduleInfo.module_ref);
            const module = modules[moduleId];
            return module ? (
              <ObjRef obj={module} showIcon={false} />
            ) : (
              <span>{moduleInfo.module_ref}</span>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</ParseObjectListPage>

<style>
  .presets-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .preset-item {
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #f9f9f9;
  }

  
  .preset-item p {
    margin: 0.25rem 0;
    color: #666;
  }

  .modules-list {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .modules-list strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #333;
  }

  .modules-list .obj-ref {
    margin-right: 0.5rem;
  }
</style>
