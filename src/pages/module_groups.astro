---
import Breadcrumb from '../components/Breadcrumb.astro';
import ParseObjectListPage from '../components/ParseObjectListPage.astro';
import ModuleGroupsNavBox from '../components/nav/ModuleGroupsNavBox.astro';
import ObjRef from '../components/obj_ref/ObjRef.astro';
import {
  MODULE_GROUPS,
  getAllModuleGroupIds,
} from '../utils/module_group_mapping';
import LocalizedText from '../components/LocalizedText.astro';
import { getModuleGroupsBreadcrumbs } from '../utils/breadcrumb';

// Load slug map to get module group slugs
const fs = await import('fs/promises');
const path = await import('path');
const projectRoot = process.cwd();
const slugMapPath = path.join(projectRoot, 'public', 'slug-map.json');

let slugMap: Record<string, string> = {};
try {
  const content = await fs.readFile(slugMapPath, 'utf-8');
  slugMap = JSON.parse(content);
} catch (error) {
  console.warn('Could not load slug map for module groups list:', error);
}

const groupIds = getAllModuleGroupIds();

// Sort groups by sort_order and add slugs
const sortedGroups = groupIds
  .map((groupId) => ({ 
    ...MODULE_GROUPS[groupId], 
    id: groupId,
    slug: slugMap[groupId] || groupId
  }))
  .sort((a, b) => (a.sort_order || 999) - (b.sort_order || 999));
---

<ParseObjectListPage
  title="Module Groups"
  description="Browse all module groups in War Robots Frontiers"
  headerImage="/images/T_AlphaUnlock.png"
>
  <Breadcrumb breadcrumbs={getModuleGroupsBreadcrumbs()} />
  <h1>Module Groups</h1>

  <p>Showing module groups from current version</p>

  <ul>
    {
      sortedGroups.map((group) => (
        <li>
          <ObjRef 
            obj={{
              id: group.id,
              name: group.name,
              parseObjectClass: 'ModuleGroup',
              parseObjectUrl: 'module_groups'
            }} 
          />
        </li>
      ))
    }
  </ul>

  <ModuleGroupsNavBox />
</ParseObjectListPage>
