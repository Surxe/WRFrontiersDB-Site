---
import { getLatestVersionForObject } from '../../utils/summary';
import { generateObjectListStaticPaths } from '../../utils/parse_object';

export const prerender = true;

export async function getStaticPaths() {
  return generateObjectListStaticPaths('PilotClass');
}

const { id } = Astro.params;

// Get the latest version for this pilot class
const latestVersion = getLatestVersionForObject(id as string, 'PilotClass');

if (!latestVersion) {
  return Astro.redirect('/pilot_classes');
}

// Redirect to the latest version
return Astro.redirect(`/pilot_classes/${id}/${latestVersion}`);
---
