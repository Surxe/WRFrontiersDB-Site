---
import type { PilotClass } from '../../types/pilot';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import LocalizedText from '../../components/LocalizedText.astro';
import ObjectPageScripts from '../../components/ObjectPageScripts.astro';
import ParseObjectPage from '../../components/ParseObjectPage.astro';
import {
  getParseObject,
  getParseObjects,
  generateObjectListStaticPaths,
} from '../../utils/parse_object';
import { getDefaultString } from '../../utils/localization';
import { generateSimpleLocalizedMetaDescriptions } from '../../utils/build_localization';
import PilotClassesNavBox from '../../components/nav/PilotClassesNavBox.astro';
import { getPilotClassDetailBreadcrumbs } from '../../utils/breadcrumb';

export async function getStaticPaths() {
  // Load slug map to generate slug-based paths
  const fs = await import('fs/promises');
  const path = await import('path');
  const projectRoot = process.cwd();
  const slugMapPath = path.join(projectRoot, 'public', 'slug-map.json');
  
  let slugMap = {};
  try {
    const content = await fs.readFile(slugMapPath, 'utf-8');
    slugMap = JSON.parse(content);
  } catch (error) {
    console.warn('Could not load slug map, falling back to ID-based paths');
    return generateObjectListStaticPaths('PilotClass');
  }

  // Get all pilot classes
  const pilotClasses = getParseObjects<PilotClass>('Objects/PilotClass.json');
  const paths = [];

  for (const [classId, pilotClass] of Object.entries(pilotClasses)) {
    // Skip classes without production_status = 'Ready' for production
    if (import.meta.env.PROD && pilotClass.production_status !== 'Ready') {
      continue;
    }

    const slug = slugMap[classId];
    if (slug) {
      paths.push({
        params: { slug },
        props: { id: classId }
      });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const { id } = Astro.props;

const pilotClass = getParseObject<PilotClass>(id, 'Objects/PilotClass.json');

// Extract English text as fallback
const defaultName = getDefaultString(pilotClass.name) || pilotClass.id;

// Generate localized meta descriptions
const localizedDescriptions = generateSimpleLocalizedMetaDescriptions(
  { Key: 'PilotClass_Meta_Description', TableNamespace: 'Web_UI' },
  { name: pilotClass.name },
  defaultName
);
---

<ParseObjectPage
  localizedDescriptions={localizedDescriptions}
  headerImage="/images/T_RobotClassesDefenderBig.png"
  type="article"
>
  <LocalizedText
    id="pilot-class-name-title"
    tag="title"
    localizationKey={pilotClass.name}
    slot="head"
  />
  <Breadcrumb breadcrumbs={getPilotClassDetailBreadcrumbs(pilotClass)} />
  <LocalizedText id="pilot-class-name" tag="h1" localizationKey={pilotClass.name} />

  <Icon iconPath={pilotClass.image_path} altText={`${defaultName} icon`} />

  <p>Language: <span id="current-lang">en</span></p>

  <PilotClassesNavBox currentClass={pilotClass} />

  <ObjectPageScripts objectData={pilotClass} />
</ParseObjectPage>
